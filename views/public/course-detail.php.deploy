                    <div class="course-detail-fact">
                        <div class="course-detail-fact-icon">
                            <span class="material-symbols-outlined text-primary">group</span>
                        </div>
                        <div>
                            <p class="course-detail-fact-label"><?= e(lang('audience')) ?></p>
