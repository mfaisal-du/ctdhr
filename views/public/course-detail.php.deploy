                        </div>
                    </div>
                    <div class="course-detail-fact">
                        <div class="course-detail-fact-icon">
                            <span class="material-symbols-outlined text-primary">verified</span>
                        </div>
                        <div>
                            <p class="course-detail-fact-label"><?= e(lang('certification')) ?></p>
                            <p class="course-detail-fact-value">CTDHR</p>
                        </div>
                    </div>
                    <?php if (!empty($course['start_date'])): ?>
                    <div class="course-detail-fact">
                        <div class="course-detail-fact-icon">
                            <span class="material-symbols-outlined text-primary">calendar_today</span>
                        </div>
                        <div>
                            <p class="course-detail-fact-label"><?= e(lang('start_date')) ?></p>
                            <p class="course-detail-fact-value"><?= e(format_date((string) $course['start_date'])) ?></p>
