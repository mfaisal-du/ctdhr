<?php declare(strict_types=1);

/** @var array<string, mixed>|null $certificate */
$valid = $valid ?? false;
$token = $token ?? '';
$certificate = $certificate ?? null;
$invalidReason = $invalidReason ?? '';
$showForm = $showForm ?? ($token === '');
$isVerifiedSuccess = $valid && $certificate !== null && !$showForm;
$isRevoked = !$valid && $certificate !== null && $invalidReason === 'revoked';
$isExpired = !$valid && $certificate !== null && $invalidReason === 'expired';
$isInvalidRecord = $isRevoked || $isExpired;

$trustFeatures = [
    ['icon' => 'lock', 'title' => lang('verify_trust_secure_title'), 'desc' => lang('verify_trust_secure_desc'), 'tone' => 'primary'],
    ['icon' => 'account_balance', 'title' => lang('verify_trust_official_title'), 'desc' => lang('verify_trust_official_desc'), 'tone' => 'secondary'],
    ['icon' => 'bolt', 'title' => lang('verify_trust_instant_title'), 'desc' => lang('verify_trust_instant_desc'), 'tone' => 'sky'],
];

$invalidTips = [
    lang('verify_certificate_invalid_tip_1'),
    lang('verify_certificate_invalid_tip_2'),
    lang('verify_certificate_invalid_tip_3'),
];

ob_start();
?>

<?php
page_hero([
    'icon' => 'verified',
    'title' => $isVerifiedSuccess ? lang('verify_report_title') : lang('verify_certificate'),
    'subtitle' => $isVerifiedSuccess ? lang('verify_report_hero_subtitle') : lang('verify_certificate_subtitle'),
    'accent' => 'secondary',
    'breadcrumbs' => [
        ['label' => lang('home'), 'href' => url('/')],
        ['label' => lang('verify_certificate')],
    ],
]);
?>

<section class="verify-section<?= $isVerifiedSuccess ? ' verify-section--report' : '' ?>">
