                        $nameParts = preg_split('/\s+/u', trim($participantName)) ?: [];
                        if (count($nameParts) >= 2) {
                            $holderInitials = mb_strtoupper(
                                mb_substr($nameParts[0], 0, 1) . mb_substr($nameParts[count($nameParts) - 1], 0, 1)
                            );
                        } elseif (count($nameParts) === 1) {
                            $holderInitials = mb_strtoupper(mb_substr($nameParts[0], 0, 2));
                        } else {
                            $holderInitials = 'CT';
                        }
