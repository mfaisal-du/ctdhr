        </header>

        <h1 class="sheet-title"><?= e(lang('print_dashboard_title')) ?></h1>
        <p class="sheet-subtitle"><?= e(lang('print_dashboard_subtitle')) ?></p>

        <div class="sheet-meta-row">
            <span class="sheet-chip sheet-chip--primary"><?= e(lang('print_dashboard_prepared_by')) ?>: <?= e($preparedBy) ?></span>
            <span class="sheet-chip sheet-chip--green"><?= e(lang('print_dashboard_as_of')) ?>: <?= e(format_date(date('Y-m-d'))) ?></span>
            <span class="sheet-chip sheet-chip--sky"><?= e(lang('print_dashboard_reporting_period')) ?>: <?= e(lang('print_dashboard_as_of')) ?> <?= e(format_date(date('Y-m-d'))) ?></span>
            <span class="sheet-chip sheet-chip--gold"><?= e(lang('insight_certificates_month')) ?>: <?= $certificatesThisMonth ?></span>
        </div>

        <section class="rpt-section">
            <h2 class="rpt-section-title"><?= e(lang('print_dashboard_section_summary')) ?></h2>
            <div class="rpt-kpi-grid">
                <div class="rpt-kpi">
                    <span class="rpt-kpi-label"><?= e(lang('total_courses')) ?></span>
                    <span class="rpt-kpi-value"><?= (int) ($metrics['total_courses'] ?? 0) ?></span>
                </div>
                <div class="rpt-kpi">
                    <span class="rpt-kpi-label"><?= e(lang('total_users')) ?></span>
                    <span class="rpt-kpi-value"><?= (int) ($metrics['total_users'] ?? 0) ?></span>
                </div>
                <div class="rpt-kpi">
                    <span class="rpt-kpi-label"><?= e(lang('total_applications')) ?></span>
                    <span class="rpt-kpi-value"><?= (int) ($metrics['total_applications'] ?? 0) ?></span>
                </div>
                <div class="rpt-kpi">
                    <span class="rpt-kpi-label"><?= e(lang('total_certificates')) ?></span>
                    <span class="rpt-kpi-value"><?= (int) ($metrics['total_certificates'] ?? 0) ?></span>
                </div>
            </div>

            <?php if ($dashboardInsights !== []): ?>
            <div class="rpt-insight-grid">
                <?php foreach ($dashboardInsights as $insight): ?>
                <div class="rpt-insight">
                    <span class="rpt-insight-label"><?= e((string) ($insight['title'] ?? '')) ?></span>
                    <span class="rpt-insight-value">
                        <?= (int) ($insight['value'] ?? 0) ?><?= e((string) ($insight['suffix'] ?? '')) ?>
                    </span>
                    <?php if (!empty($insight['meta'])): ?>
                    <span class="rpt-insight-meta"><?= e((string) $insight['meta']) ?></span>
                    <?php endif; ?>
                </div>
                <?php endforeach; ?>
            </div>
            <?php endif; ?>
        </section>

        <section class="rpt-section">
            <h2 class="rpt-section-title"><?= e(lang('application_funnel')) ?></h2>
            <?php if (($funnel['stages'] ?? []) === []): ?>
            <p class="rpt-empty"><?= e(lang('chart_no_data')) ?></p>
            <?php else: ?>
                <?php
                $funnelColors = ['', 'rpt-bar-fill--green', 'rpt-bar-fill--sky', 'rpt-bar-fill--gold'];
                foreach ($funnel['stages'] as $i => $stage):
                    $count = (int) ($stage['count'] ?? 0);
                ?>
                <div class="rpt-bar-row">
                    <span class="rpt-bar-label"><?= e((string) ($stage['label'] ?? '')) ?></span>
                    <div class="rpt-bar-track">
                        <span class="rpt-bar-fill <?= e($funnelColors[$i] ?? '') ?>" style="width: <?= $barPct($count, $funnelMax) ?>%"></span>
                    </div>
                    <span class="rpt-bar-count"><?= $count ?></span>
                </div>
                <?php endforeach; ?>
            <?php endif; ?>
        </section>

        <section class="rpt-section">
            <h2 class="rpt-section-title"><?= e(lang('attendance_overview')) ?></h2>
            <div class="rpt-highlight">
                <div>
                    <strong style="font-size:0.68rem;color:#6b7280;"><?= e(lang('attendance_rate')) ?></strong>
                    <div class="rpt-highlight-value"><?= (int) ($attendance['rate'] ?? 0) ?>%</div>
                </div>
                <div style="font-size:0.68rem;color:#5c6478;">
                    <?= e(lang('attendance_present')) ?>: <strong><?= (int) ($attendance['present'] ?? 0) ?></strong><br>
                    <?= e(lang('attendance_absent')) ?>: <strong><?= (int) ($attendance['absent'] ?? 0) ?></strong><br>
                    <?= e(lang('attendance_excused')) ?>: <strong><?= (int) ($attendance['excused'] ?? 0) ?></strong>
                </div>
            </div>
        </section>
