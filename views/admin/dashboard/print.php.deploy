        .rpt-bar-row {
            display: grid;
            grid-template-columns: minmax(0, 1.1fr) minmax(0, 1.4fr) 2.2rem;
            gap: 0.35rem;
            align-items: center;
            margin-bottom: 0.32rem;
            font-size: 0.68rem;
        }

        .rpt-bar-label {
            color: #374151;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .rpt-bar-track {
            height: 0.45rem;
            border-radius: 999px;
            background: rgba(66, 90, 173, 0.1);
            overflow: hidden;
        }

        .rpt-bar-fill {
            display: block;
            height: 100%;
            border-radius: 999px;
            background: linear-gradient(90deg, #284194, #425aad);
        }

        .rpt-bar-fill--green { background: linear-gradient(90deg, #106e18, #30872f); }
        .rpt-bar-fill--sky { background: linear-gradient(90deg, #0090cc, #00b0ff); }
        .rpt-bar-fill--gold { background: linear-gradient(90deg, #c9a000, #ffd600); }
        .rpt-bar-fill--amber { background: linear-gradient(90deg, #b45309, #f59e0b); }
        .rpt-bar-fill--magenta { background: linear-gradient(90deg, #be185d, #d81b60); }

        .rpt-bar-count {
            text-align: <?= $metaAlign ?>;
            font-weight: 700;
            color: #152550;
            font-variant-numeric: tabular-nums;
        }

        table.rpt-table {
            width: 100%;
            border-collapse: collapse;
