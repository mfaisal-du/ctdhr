</div>

<div class="sheet-wrap rpt-page-break">
    <div class="sheet">
        <div class="sheet-rainbow" aria-hidden="true"></div>

        <section class="rpt-section">
            <h2 class="rpt-section-title"><?= e(lang('print_dashboard_section_operations')) ?></h2>
            <div class="rpt-cols">
                <div class="rpt-panel">
                    <h3 class="rpt-panel-title"><?= e(lang('pending_applications_aging')) ?></h3>
                    <?php if ((int) ($pendingAging['total'] ?? 0) === 0): ?>
                    <p class="rpt-empty"><?= e(lang('insight_pending_clear_meta')) ?></p>
                    <?php else: ?>
                        <?php foreach ($pendingAging['buckets'] as $bucket):
                            $count = (int) ($bucket['count'] ?? 0);
                            $severity = (string) ($bucket['severity'] ?? 'ok');
                            $fillClass = $severity === 'critical' ? 'rpt-bar-fill--magenta' : ($severity === 'warning' ? 'rpt-bar-fill--amber' : 'rpt-bar-fill--green');
                        ?>
                        <div class="rpt-bar-row">
                            <span class="rpt-bar-label"><?= e((string) ($bucket['label'] ?? '')) ?></span>
                            <div class="rpt-bar-track">
                                <span class="rpt-bar-fill <?= e($fillClass) ?>" style="width: <?= $barPct($count, $agingMax) ?>%"></span>
                            </div>
                            <span class="rpt-bar-count"><?= $count ?></span>
                        </div>
                        <?php endforeach; ?>
                    <?php endif; ?>
                </div>

                <div class="rpt-panel">
                    <h3 class="rpt-panel-title"><?= e(lang('upcoming_course_deadlines')) ?></h3>
                    <?php if ($upcomingDeadlines === []): ?>
                    <p class="rpt-empty"><?= e(lang('no_upcoming_deadlines')) ?></p>
                    <?php else: ?>
                    <table class="rpt-table">
                        <thead>
                            <tr>
                                <th><?= e(lang('courses')) ?></th>
                                <th><?= e(lang('date')) ?></th>
                                <th><?= e(lang('status')) ?></th>
                            </tr>
                        </thead>
                        <tbody>
                            <?php foreach (array_slice($upcomingDeadlines, 0, 6) as $item):
                                $daysLeft = (int) ($item['days_left'] ?? 0);
                                $daysLabel = $daysLeft === 0
                                    ? lang('days_left_today')
                                    : str_replace(':count', (string) $daysLeft, lang('days_left'));
                                $urgency = (string) ($item['urgency'] ?? 'normal');
                            ?>
                            <tr>
                                <td><?= e((string) ($item['title'] ?? '')) ?></td>
                                <td>
                                    <?= e((string) ($item['date_label'] ?? '')) ?>
                                    <span class="rpt-badge rpt-badge--<?= e($urgency) ?>"><?= e($daysLabel) ?></span>
                                </td>
                                <td><?= e((string) ($item['type_label'] ?? '')) ?></td>
                            </tr>
                            <?php endforeach; ?>
                        </tbody>
                    </table>
                    <?php endif; ?>
                </div>
            </div>
        </section>

        <section class="rpt-section">
            <h2 class="rpt-section-title"><?= e(lang('print_dashboard_section_performance')) ?></h2>
            <div class="rpt-cols">
                <div class="rpt-panel">
                    <h3 class="rpt-panel-title"><?= e(lang('top_courses_by_applications')) ?></h3>
                    <?php
                    $hasTop = false;
                    foreach ($topCourses['courses'] ?? [] as $course) {
                        if ((int) ($course['count'] ?? 0) > 0) {
                            $hasTop = true;
                            break;
                        }
                    }
                    ?>
                    <?php if (!$hasTop): ?>
                    <p class="rpt-empty"><?= e(lang('chart_no_data')) ?></p>
                    <?php else: ?>
                        <?php foreach ($topCourses['courses'] as $course):
                            $count = (int) ($course['count'] ?? 0);
                            if ($count <= 0) {
                                continue;
                            }
                        ?>
                        <div class="rpt-bar-row">
                            <span class="rpt-bar-label"><?= e((string) ($course['title'] ?? '')) ?></span>
                            <div class="rpt-bar-track">
                                <span class="rpt-bar-fill" style="width: <?= $barPct($count, $topMax) ?>%"></span>
                            </div>
                            <span class="rpt-bar-count"><?= $count ?></span>
                        </div>
                        <?php endforeach; ?>
                    <?php endif; ?>
                </div>

                <div class="rpt-panel">
                    <h3 class="rpt-panel-title"><?= e(lang('course_capacity_utilization')) ?></h3>
                    <?php if (($capacity['courses'] ?? []) === []): ?>
                    <p class="rpt-empty"><?= e(lang('chart_no_data')) ?></p>
                    <?php else: ?>
                        <?php foreach ($capacity['courses'] as $course):
                            $percent = (int) ($course['percent'] ?? 0);
                            $fillClass = $percent >= 90 ? 'rpt-bar-fill--magenta' : ($percent >= 70 ? 'rpt-bar-fill--amber' : 'rpt-bar-fill--sky');
                        ?>
                        <div class="rpt-bar-row">
                            <span class="rpt-bar-label"><?= e((string) ($course['title'] ?? '')) ?></span>
                            <div class="rpt-bar-track">
                                <span class="rpt-bar-fill <?= e($fillClass) ?>" style="width: <?= $percent ?>%"></span>
                            </div>
                            <span class="rpt-bar-count"><?= $percent ?>%</span>
                        </div>
                        <div style="font-size:0.58rem;color:#6b7280;margin:-0.15rem 0 0.28rem 0;">
                            <?= e(str_replace(
                                [':approved', ':max'],
                                [(string) (int) ($course['approved'] ?? 0), (string) (int) ($course['max'] ?? 0)],
                                lang('capacity_seats')
                            )) ?>
                        </div>
                        <?php endforeach; ?>
                    <?php endif; ?>
                </div>
            </div>
        </section>
    </div>
</div>

<div class="sheet-wrap rpt-page-break">
    <div class="sheet">
        <div class="sheet-rainbow" aria-hidden="true"></div>

        <section class="rpt-section">
            <h2 class="rpt-section-title"><?= e(lang('print_dashboard_section_trends')) ?></h2>
            <div class="rpt-charts-grid">
                <div class="rpt-chart-box">
                    <h3 class="rpt-chart-title"><?= e(lang('applications_trend')) ?></h3>
                    <div class="rpt-chart-canvas"><canvas id="appsTrendChart"></canvas></div>
                </div>
                <div class="rpt-chart-box">
                    <h3 class="rpt-chart-title"><?= e(lang('user_growth')) ?></h3>
                    <div class="rpt-chart-canvas"><canvas id="userGrowthChart"></canvas></div>
                </div>
                <div class="rpt-chart-box">
                    <h3 class="rpt-chart-title"><?= e(lang('courses_by_status')) ?></h3>
                    <div class="rpt-chart-canvas"><canvas id="coursesStatusChart"></canvas></div>
                </div>
                <div class="rpt-chart-box">
                    <h3 class="rpt-chart-title"><?= e(lang('certificates_trend')) ?></h3>
                    <div class="rpt-chart-canvas"><canvas id="certsTrendChart"></canvas></div>
                </div>
            </div>
        </section>

        <section class="rpt-section">
            <h2 class="rpt-section-title"><?= e(lang('applications_by_status')) ?></h2>
            <?php if (count($applicationsStatusChart['labels'] ?? []) === 0): ?>
            <p class="rpt-empty"><?= e(lang('chart_no_data')) ?></p>
            <?php else: ?>
            <table class="rpt-table">
                <thead>
                    <tr>
                        <th><?= e(lang('status')) ?></th>
                        <th><?= e(lang('applications')) ?></th>
                    </tr>
                </thead>
                <tbody>
                    <?php foreach ($applicationsStatusChart['labels'] as $i => $label): ?>
                    <tr>
                        <td><?= e((string) $label) ?></td>
                        <td><?= (int) ($applicationsStatusChart['data'][$i] ?? 0) ?></td>
                    </tr>
                    <?php endforeach; ?>
                </tbody>
            </table>
            <?php endif; ?>
        </section>

        <footer class="sheet-footer">
            <div class="sheet-signatures">
                <div class="sheet-sig-block">
                    <label><?= e(lang('print_dashboard_prepared_by')) ?></label>
                    <div class="sheet-sig-line"></div>
                </div>
                <div class="sheet-sig-block">
                    <label><?= e(lang('print_dashboard_coordinator_sig')) ?></label>
                    <div class="sheet-sig-line"></div>
                </div>
            </div>
            <p class="sheet-disclaimer"><?= e(lang('print_dashboard_disclaimer')) ?></p>
        </footer>
    </div>
</div>

<script src="<?= e(asset('vendor/chart.umd.min.js')) ?>"></script>
<script>
(function () {
    'use strict';

    var cfg = {
        apps: <?= json_encode($applicationsChart, JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT | JSON_UNESCAPED_UNICODE) ?>,
        userGrowth: <?= json_encode($userGrowth, JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT | JSON_UNESCAPED_UNICODE) ?>,
        courses: <?= json_encode($coursesChart, JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT | JSON_UNESCAPED_UNICODE) ?>,
        certificates: <?= json_encode($certificatesChart, JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT | JSON_UNESCAPED_UNICODE) ?>,
        rtl: <?= $rtl ? 'true' : 'false' ?>
    };

    var brand = {
        primary: '#284194',
        secondary: '#30872F',
        sky: '#00B0FF',
        gold: '#FFD600',
        magenta: '#D81B60'
    };

    function initCharts() {
        if (typeof Chart === 'undefined') {
            return false;
        }

        Chart.defaults.font.family = cfg.rtl ? "'Cairo', sans-serif" : "'Segoe UI', sans-serif";
        Chart.defaults.font.size = 9;
        Chart.defaults.color = '#5c6478';

        if (cfg.apps.labels && cfg.apps.labels.length) {
            new Chart(document.getElementById('appsTrendChart'), {
                type: 'line',
                data: {
                    labels: cfg.apps.labels,
                    datasets: [{
                        data: cfg.apps.data,
                        borderColor: brand.primary,
                        backgroundColor: 'rgba(40, 65, 148, 0.12)',
                        fill: true,
                        tension: 0.3,
                        pointRadius: 2,
                        borderWidth: 1.5
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { display: false }, ticks: { font: { size: 8 }, maxTicksLimit: 6 } },
                        y: { beginAtZero: true, ticks: { precision: 0, maxTicksLimit: 4 } }
                    }
                }
            });
        }

        if (cfg.userGrowth.labels && cfg.userGrowth.labels.length) {
            new Chart(document.getElementById('userGrowthChart'), {
                type: 'bar',
                data: {
                    labels: cfg.userGrowth.labels,
                    datasets: [{
                        data: cfg.userGrowth.data,
                        backgroundColor: 'rgba(48, 135, 47, 0.65)',
                        borderColor: brand.secondary,
                        borderWidth: 1,
                        borderRadius: 4,
                        maxBarThickness: 18
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { display: false }, ticks: { font: { size: 8 } } },
                        y: { beginAtZero: true, ticks: { precision: 0, maxTicksLimit: 4 } }
                    }
                }
            });
        }

        if (cfg.courses.labels && cfg.courses.labels.length) {
            new Chart(document.getElementById('coursesStatusChart'), {
                type: 'doughnut',
                data: {
                    labels: cfg.courses.labels,
                    datasets: [{
                        data: cfg.courses.data,
                        backgroundColor: [brand.primary, '#425AAD', brand.secondary, brand.sky, brand.gold, brand.magenta],
                        borderWidth: 1,
                        borderColor: '#fff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { position: 'bottom', labels: { boxWidth: 8, font: { size: 8 } } } },
                    cutout: '55%'
                }
            });
        }

        if (cfg.certificates.labels && cfg.certificates.labels.length) {
            new Chart(document.getElementById('certsTrendChart'), {
                type: 'bar',
                data: {
                    labels: cfg.certificates.labels,
                    datasets: [{
                        data: cfg.certificates.data,
                        backgroundColor: 'rgba(0, 176, 255, 0.55)',
                        borderColor: brand.sky,
                        borderWidth: 1,
                        borderRadius: 4,
                        maxBarThickness: 18
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { display: false }, ticks: { font: { size: 8 } } },
                        y: { beginAtZero: true, ticks: { precision: 0, maxTicksLimit: 4 } }
                    }
                }
            });
        }

        return true;
    }

    function boot(attempt) {
        attempt = attempt || 0;
        if (initCharts() || attempt >= 30) {
            var btn = document.getElementById('printReportBtn');
            if (btn) {
                btn.addEventListener('click', function () {
                    window.print();
                });
            }
            return;
        }
        window.setTimeout(function () { boot(attempt + 1); }, 100);
    }

    if (document.readyState === 'complete') {
        boot(0);
    } else {
        window.addEventListener('load', function () { boot(0); });
    }
})();
</script>
</body>
</html>