        .sheet-chip--primary { background: rgba(40, 65, 148, 0.1); color: #284194; }
        .sheet-chip--green { background: rgba(16, 110, 24, 0.1); color: #106e18; }
        .sheet-chip--sky { background: rgba(0, 176, 255, 0.12); color: #0077aa; }
