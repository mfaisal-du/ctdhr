<?php declare(strict_types=1);

$metrics = $metrics ?? [];
$dashboardInsights = $dashboardInsights ?? [];
$dashboardAnalytics = $dashboardAnalytics ?? [];
$applicationsChart = $applicationsChart ?? ['labels' => [], 'data' => []];
$coursesChart = $coursesChart ?? ['labels' => [], 'data' => []];
$applicationsStatusChart = $applicationsStatusChart ?? ['labels' => [], 'data' => []];
$certificatesChart = $certificatesChart ?? ['labels' => [], 'data' => []];

$pendingAging = $dashboardAnalytics['pendingAging'] ?? ['total' => 0, 'buckets' => []];
$topCourses = $dashboardAnalytics['topCourses'] ?? ['courses' => []];
$funnel = $dashboardAnalytics['funnel'] ?? ['stages' => []];
$capacity = $dashboardAnalytics['capacity'] ?? ['courses' => []];
$upcomingDeadlines = $dashboardAnalytics['upcomingDeadlines'] ?? [];
$attendance = $dashboardAnalytics['attendance'] ?? ['total' => 0, 'present' => 0, 'absent' => 0, 'excused' => 0, 'rate' => 0];
$certificatesThisMonth = (int) ($dashboardAnalytics['certificatesThisMonth'] ?? 0);
$userGrowth = $dashboardAnalytics['userGrowth'] ?? ['labels' => [], 'data' => []];

$preparedBy = (string) ($preparedBy ?? lang('system'));
$printedAt = (string) ($printedAt ?? format_date(date('Y-m-d')) . ' · ' . date('H:i'));
$reportRef = 'DBR-' . date('Ymd');

$funnelMax = 1;
foreach ($funnel['stages'] as $stage) {
    $funnelMax = max($funnelMax, (int) ($stage['count'] ?? 0));
}

$agingMax = 1;
foreach ($pendingAging['buckets'] ?? [] as $bucket) {
    $agingMax = max($agingMax, (int) ($bucket['count'] ?? 0));
}

$topMax = 1;
foreach ($topCourses['courses'] ?? [] as $course) {
    $topMax = max($topMax, (int) ($course['count'] ?? 0));
}

$barPct = static function (int $value, int $max): int {
    if ($max <= 0) {
        return 0;
    }

    return (int) round(min(100, ($value / $max) * 100));
};

$rtl = is_rtl();
$textAlign = $rtl ? 'right' : 'left';
$metaAlign = $rtl ? 'left' : 'right';
?>
<!DOCTYPE html>
<html lang="<?= e(current_locale()) ?>" dir="<?= $rtl ? 'rtl' : 'ltr' ?>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><?= e($pageTitle ?? lang('print_dashboard_title')) ?></title>
    <style>
        @page {
