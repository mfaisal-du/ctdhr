        }

        .rpt-kpi-value {
            font-size: 1.15rem;
            font-weight: 700;
            color: #152550;
            line-height: 1.1;
        }

        .rpt-insight-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 0.4rem;
        }

        .rpt-insight {
