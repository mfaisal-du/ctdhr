            margin-bottom: 0.55rem;
        }

        .rpt-kpi {
            padding: 0.55rem 0.6rem;
            border-radius: 0.45rem;
            border: 1px solid rgba(66, 90, 173, 0.14);
            background: linear-gradient(180deg, rgba(66, 90, 173, 0.05) 0%, #fff 100%);
