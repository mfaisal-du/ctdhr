                        </p>
                        <?php endif; ?>
                        <canvas id="certificatesChart"<?= $hasCertsTrend ? '' : ' class="is-hidden"' ?>></canvas>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="admin-dashboard-activity" aria-label="<?= e(lang('recent_activity')) ?>">
        <div class="admin-panel admin-dashboard-panel admin-dashboard-panel--activity">
            <div class="admin-panel-header">
                <h3 class="admin-panel-title">
                    <span class="admin-panel-title-icon admin-panel-title-icon--sky">
                        <span class="material-symbols-outlined">history</span>
                    </span>
                    <?= e(lang('recent_activity')) ?>
                </h3>
            </div>
            <div class="admin-panel-body">
                <?php if (empty($recentActivity)): ?>
                    <p class="admin-dashboard-empty">
                        <span class="material-symbols-outlined">inbox</span>
                        <?= e(lang('no_activity')) ?>
                    </p>
                <?php else: ?>
                    <div class="admin-activity-list">
                        <?php foreach ($recentActivity as $log): ?>
                            <div class="admin-activity-item">
                                <div class="admin-activity-icon">
                                    <span class="material-symbols-outlined">history_edu</span>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <p class="admin-activity-title"><?= e($log['action']) ?></p>
                                    <p class="admin-activity-meta">
                                        <?= e($log['username'] ?? lang('system')) ?>
                                        <span aria-hidden="true">·</span>
                                        <?= e($log['created_at']) ?>
                                    </p>
                                </div>
                            </div>
                        <?php endforeach; ?>
                    </div>
                <?php endif; ?>
            </div>
        </div>
    </section>
</div>

<script>
window.__ADMIN_DASHBOARD_CHARTS__ = {
    apps: <?= json_encode($applicationsChart ?? ['labels' => [], 'data' => []], JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT | JSON_UNESCAPED_UNICODE) ?>,
    courses: <?= json_encode($coursesChart ?? ['labels' => [], 'data' => []], JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT | JSON_UNESCAPED_UNICODE) ?>,
    appsStatus: <?= json_encode($applicationsStatusChart ?? ['labels' => [], 'data' => []], JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT | JSON_UNESCAPED_UNICODE) ?>,
    certificates: <?= json_encode($certificatesChart ?? ['labels' => [], 'data' => []], JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT | JSON_UNESCAPED_UNICODE) ?>,
    pendingAging: <?= json_encode(['labels' => $pendingAging['labels'] ?? [], 'data' => $pendingAging['data'] ?? []], JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT | JSON_UNESCAPED_UNICODE) ?>,
    topCourses: <?= json_encode(['labels' => $topCourses['labels'] ?? [], 'data' => $topCourses['data'] ?? []], JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT | JSON_UNESCAPED_UNICODE) ?>,
    funnel: <?= json_encode(['labels' => $funnel['labels'] ?? [], 'data' => $funnel['data'] ?? [], 'colors' => array_column($funnel['stages'] ?? [], 'color')], JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT | JSON_UNESCAPED_UNICODE) ?>,
    attendance: <?= json_encode(['labels' => $attendance['labels'] ?? [], 'data' => $attendance['data'] ?? []], JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT | JSON_UNESCAPED_UNICODE) ?>,
    userGrowth: <?= json_encode($userGrowth ?? ['labels' => [], 'data' => []], JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT | JSON_UNESCAPED_UNICODE) ?>,
    labels: {
        applications: <?= json_encode(lang('applications'), JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT | JSON_UNESCAPED_UNICODE) ?>,
        certificates: <?= json_encode(lang('certificates'), JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT | JSON_UNESCAPED_UNICODE) ?>,
        users: <?= json_encode(lang('total_users'), JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT | JSON_UNESCAPED_UNICODE) ?>,
        utilization: <?= json_encode(lang('course_capacity_utilization'), JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT | JSON_UNESCAPED_UNICODE) ?>
    },
    rtl: <?= is_rtl() ? 'true' : 'false' ?>,
    flags: {
        apps: <?= $hasAppsTrend ? 'true' : 'false' ?>,
        courses: <?= $hasCoursesStatus ? 'true' : 'false' ?>,
        appsStatus: <?= $hasAppsStatus ? 'true' : 'false' ?>,
        certificates: <?= $hasCertsTrend ? 'true' : 'false' ?>,
        pendingAging: <?= $hasPendingAging ? 'true' : 'false' ?>,
        topCourses: <?= $hasTopCourses ? 'true' : 'false' ?>,
        funnel: <?= $hasFunnel ? 'true' : 'false' ?>,
        attendance: <?= $hasAttendance ? 'true' : 'false' ?>,
        userGrowth: <?= $hasUserGrowth ? 'true' : 'false' ?>
    }
};
</script>
<script>
(function () {
    'use strict';

    function animateCounters() {
        var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        document.querySelectorAll('[data-count]').forEach(function (el) {
            var target = parseInt(el.getAttribute('data-count') || '0', 10);
            if (prefersReducedMotion || target === 0) {
                el.textContent = String(target);
                return;
            }
            var duration = 700;
            var start = performance.now();
            function tick(now) {
                var progress = Math.min((now - start) / duration, 1);
                var eased = 1 - Math.pow(1 - progress, 3);
                el.textContent = String(Math.round(target * eased));
                if (progress < 1) requestAnimationFrame(tick);
            }
            requestAnimationFrame(tick);
        });
    }

    function doughnutLegendOptions(cfg) {
        return {
            position: window.matchMedia('(min-width: 1024px)').matches ? 'right' : 'bottom',
            align: 'center',
            rtl: !!cfg.rtl,
            labels: {
                boxWidth: 8,
                padding: 8,
                usePointStyle: true,
                font: { size: 9 },
                generateLabels: function (chart) {
                    var data = chart.data;
                    if (!data.labels || !data.datasets.length) {
                        return [];
                    }
                    return data.labels.map(function (label, index) {
                        var value = data.datasets[0].data[index];
                        return {
                            text: label + ' (' + value + ')',
                            fillStyle: data.datasets[0].backgroundColor[index],
                            strokeStyle: '#ffffff',
                            lineWidth: 1,
                            hidden: false,
                            index: index
                        };
                    });
                }
            }
        };
    }

    function horizontalBarOptions(cfg, maxTicks) {
        return {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: {
                    beginAtZero: true,
                    grid: { color: 'rgba(66, 90, 173, 0.06)' },
                    ticks: { precision: 0, maxTicksLimit: maxTicks || 5 }
                },
                y: {
                    grid: { display: false },
                    ticks: { font: { size: 10 }, autoSkip: false }
                }
            }
        };
    }

    function createChart(canvasId, config) {
        var canvas = document.getElementById(canvasId);
        if (!canvas || canvas.classList.contains('is-hidden')) {
            return null;
        }
        try {
            var chart = new Chart(canvas, config);
            window.requestAnimationFrame(function () {
                chart.resize();
            });
            return chart;
        } catch (error) {
            console.error('Dashboard chart failed:', canvasId, error);
            return null;
        }
    }

    function initDashboardCharts() {
        if (typeof Chart === 'undefined' || !window.__ADMIN_DASHBOARD_CHARTS__) {
            return false;
        }

        var cfg = window.__ADMIN_DASHBOARD_CHARTS__;
        var brandColors = {
            primary: '#284194',
            secondary: '#30872F',
            sky: '#00B0FF',
            magenta: '#D81B60',
            gold: '#FFD600',
            primaryLight: '#425AAD',
            amber: '#D97706',
            violet: '#7C3AED'
        };

        Chart.defaults.font.family = cfg.rtl ? "'Cairo', sans-serif" : "'Inter', 'Cairo', sans-serif";
        Chart.defaults.font.size = 11;
        Chart.defaults.color = '#5c6478';

        if (cfg.flags.pendingAging) {
            createChart('pendingAgingChart', {
                type: 'bar',
                data: {
                    labels: cfg.pendingAging.labels,
                    datasets: [{
                        data: cfg.pendingAging.data,
                        backgroundColor: ['rgba(48, 135, 47, 0.75)', 'rgba(0, 176, 255, 0.75)', 'rgba(217, 119, 6, 0.8)', 'rgba(216, 27, 96, 0.8)'],
                        borderRadius: 6,
                        maxBarThickness: 32
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { display: false }, ticks: { maxRotation: 45, minRotation: 0, font: { size: 9 } } },
                        y: { beginAtZero: true, grid: { color: 'rgba(66, 90, 173, 0.06)' }, ticks: { precision: 0, maxTicksLimit: 4 } }
                    }
                }
            });
        }

        if (cfg.flags.topCourses) {
            createChart('topCoursesChart', {
                type: 'bar',
                data: {
                    labels: cfg.topCourses.labels,
                    datasets: [{
                        label: cfg.labels.applications,
                        data: cfg.topCourses.data,
                        backgroundColor: 'rgba(40, 65, 148, 0.65)',
                        borderColor: brandColors.primary,
                        borderWidth: 1,
                        borderRadius: 6,
                        maxBarThickness: 22
                    }]
                },
                options: horizontalBarOptions(cfg, 5)
            });
        }

        if (cfg.flags.funnel) {
            var funnelColors = cfg.funnel.colors && cfg.funnel.colors.length
                ? cfg.funnel.colors
                : [brandColors.primary, brandColors.secondary, brandColors.sky, brandColors.gold];
            createChart('funnelChart', {
                type: 'bar',
                data: {
                    labels: cfg.funnel.labels,
                    datasets: [{
                        data: cfg.funnel.data,
                        backgroundColor: funnelColors.map(function (c) { return c + 'CC'; }),
                        borderRadius: 6,
                        maxBarThickness: 28
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { display: false }, ticks: { font: { size: 9 } } },
                        y: { beginAtZero: true, grid: { color: 'rgba(66, 90, 173, 0.06)' }, ticks: { precision: 0, maxTicksLimit: 5 } }
                    }
                }
            });
        }

        if (cfg.flags.attendance) {
            createChart('attendanceChart', {
                type: 'doughnut',
                data: {
                    labels: cfg.attendance.labels,
                    datasets: [{
                        data: cfg.attendance.data,
                        backgroundColor: [brandColors.secondary, brandColors.magenta, brandColors.amber],
                        borderWidth: 2,
                        borderColor: '#ffffff',
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    layout: { padding: 4 },
                    plugins: { legend: doughnutLegendOptions(cfg) },
                    cutout: '58%'
                }
            });
        }

        if (cfg.flags.userGrowth) {
            createChart('userGrowthChart', {
                type: 'line',
                data: {
                    labels: cfg.userGrowth.labels,
                    datasets: [{
                        label: cfg.labels.users,
                        data: cfg.userGrowth.data,
                        borderColor: brandColors.secondary,
                        backgroundColor: 'rgba(48, 135, 47, 0.12)',
                        fill: true,
                        tension: 0.35,
                        pointBackgroundColor: brandColors.sky,
                        pointBorderColor: '#fff',
                        pointBorderWidth: 1.5,
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { display: false }, ticks: { maxTicksLimit: 6, font: { size: 10 } } },
                        y: { beginAtZero: true, grid: { color: 'rgba(66, 90, 173, 0.06)' }, ticks: { precision: 0, maxTicksLimit: 5 } }
                    }
                }
            });
        }

        if (cfg.flags.apps) {
            createChart('applicationsChart', {
                type: 'line',
                data: {
                    labels: cfg.apps.labels,
                    datasets: [{
                        label: cfg.labels.applications,
                        data: cfg.apps.data,
                        borderColor: brandColors.primary,
                        backgroundColor: 'rgba(40, 65, 148, 0.12)',
                        fill: true,
                        tension: 0.35,
                        pointBackgroundColor: brandColors.sky,
                        pointBorderColor: '#fff',
                        pointBorderWidth: 1.5,
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { display: false }, ticks: { maxTicksLimit: 6, font: { size: 10 } } },
                        y: { beginAtZero: true, grid: { color: 'rgba(66, 90, 173, 0.06)' }, ticks: { precision: 0, maxTicksLimit: 5 } }
                    }
                }
            });
        }

        if (cfg.flags.courses) {
            createChart('coursesChart', {
                type: 'doughnut',
                data: {
                    labels: cfg.courses.labels,
                    datasets: [{
                        data: cfg.courses.data,
                        backgroundColor: [brandColors.primary, brandColors.primaryLight, brandColors.secondary, brandColors.sky, brandColors.gold, brandColors.magenta, '#9B59B6'],
                        borderWidth: 2,
                        borderColor: '#ffffff',
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    layout: { padding: 4 },
                    plugins: { legend: doughnutLegendOptions(cfg) },
                    cutout: '62%'
                }
            });
        }

        if (cfg.flags.appsStatus) {
            createChart('applicationsStatusChart', {
                type: 'doughnut',
                data: {
                    labels: cfg.appsStatus.labels,
                    datasets: [{
                        data: cfg.appsStatus.data,
                        backgroundColor: [brandColors.gold, brandColors.secondary, brandColors.magenta, brandColors.sky, '#9B59B6'],
                        borderWidth: 2,
                        borderColor: '#ffffff',
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    layout: { padding: 4 },
                    plugins: { legend: doughnutLegendOptions(cfg) },
                    cutout: '62%'
                }
            });
        }

        if (cfg.flags.certificates) {
            createChart('certificatesChart', {
                type: 'bar',
                data: {
                    labels: cfg.certificates.labels,
                    datasets: [{
                        label: cfg.labels.certificates,
                        data: cfg.certificates.data,
                        backgroundColor: 'rgba(0, 176, 255, 0.55)',
                        borderColor: brandColors.sky,
                        borderWidth: 1,
                        borderRadius: 6,
                        maxBarThickness: 28
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { display: false }, ticks: { maxTicksLimit: 6, font: { size: 10 } } },
                        y: { beginAtZero: true, grid: { color: 'rgba(66, 90, 173, 0.06)' }, ticks: { precision: 0, maxTicksLimit: 5 } }
                    }
                }
            });
        }

        return true;
    }

    function waitForChartLibrary(attempt) {
        attempt = attempt || 0;
        if (initDashboardCharts()) {
            return;
        }
        if (attempt < 40) {
            window.setTimeout(function () {
                waitForChartLibrary(attempt + 1);
            }, 100);
        }
    }

    function boot() {
        animateCounters();
        waitForChartLibrary(0);
    }

    if (document.readyState === 'complete') {
        boot();
    } else {
        window.addEventListener('load', boot);
    }
})();
</script>