$userGrowth = $dashboardAnalytics['userGrowth'] ?? ['labels' => [], 'data' => []];

$hasAppsTrend = count($applicationsChart['labels'] ?? []) > 0;
$hasCoursesStatus = count($coursesChart['labels'] ?? []) > 0;
$hasAppsStatus = count($applicationsStatusChart['labels'] ?? []) > 0;
$hasCertsTrend = count($certificatesChart['labels'] ?? []) > 0;
$hasPendingAging = (int) ($pendingAging['total'] ?? 0) > 0;
$hasTopCourses = count($topCourses['labels'] ?? []) > 0;
$hasFunnel = array_sum($funnel['data'] ?? []) > 0;
$hasCapacity = count($capacity['courses'] ?? []) > 0;
$hasAttendance = (int) ($attendance['total'] ?? 0) > 0;
$hasUserGrowth = array_sum($userGrowth['data'] ?? []) > 0;

$insightIconClasses = [
    'amber' => 'admin-insight-card-icon--amber',
