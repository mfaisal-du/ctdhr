$tabIcons = [
    'general' => 'tune',
    'smtp' => 'mail',
    'ldap' => 'group',
    'attendance' => 'fact_check',
    'language' => 'translate',
    'security' => 'shield',
];

$ldapEnabled = ($s['ldap_enabled'] ?? 'false') === 'true';
$maintenanceOn = ($s['maintenance_mode'] ?? 'false') === 'true';
