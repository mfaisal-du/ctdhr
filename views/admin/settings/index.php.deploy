    'ldap' => ['class' => 'ldap', 'icon' => 'group', 'desc' => lang('settings_ldap_desc')],
    'attendance' => ['class' => 'attendance', 'icon' => 'fact_check', 'desc' => lang('settings_attendance_desc')],
    'language' => ['class' => 'language', 'icon' => 'translate', 'desc' => lang('settings_language_desc')],
    'security' => ['class' => 'security', 'icon' => 'shield', 'desc' => lang('settings_security_desc')],
];
$activeSection = $tabSections[$tab] ?? $tabSections['general'];
