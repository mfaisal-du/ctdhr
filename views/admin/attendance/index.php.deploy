            <?= csrf_field() ?>
            <input type="hidden" name="session_date" value="<?= e($sessionDate) ?>">
            <button type="submit" class="courses-btn-secondary courses-btn-secondary--sm"><?= e(lang('unlock_session')) ?></button>
        </form>
    </div>
    <?php endif; ?>

    <form method="GET" action="<?= e(url('admin/attendance/' . $course['id'])) ?>" class="courses-filters courses-filters--inline">
        <div class="courses-filter-group">
            <label class="admin-filter-label" for="session-select"><?= e(lang('select_session')) ?></label>
            <div class="admin-select-wrap admin-select-wrap--sm admin-select-wrap--filter admin-select-wrap--wide">
                <select id="session-select" name="session" class="admin-form-select courses-filter-select" onchange="this.form.submit()" aria-label="<?= e(lang('session')) ?>">
                    <?php foreach ($sessionEntries as $entry): ?>
                    <option value="<?= e($entry['key']) ?>" <?= $sessionDate === $entry['key'] ? 'selected' : '' ?>>
