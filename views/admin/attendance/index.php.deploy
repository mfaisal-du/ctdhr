    <form method="POST" action="<?= e(url('admin/attendance/' . $course['id'] . '/mark')) ?>" id="attendanceMarkForm">
        <?= csrf_field() ?>
        <input type="hidden" name="session_date" value="<?= e($sessionDate) ?>">

        <div class="courses-bulk-bar courses-bulk-bar--attendance">
            <button type="button" class="courses-bulk-btn courses-bulk-btn--approve" data-attendance-action="all-present"<?= $sessionLocked ? ' disabled' : '' ?>>
                <span class="material-symbols-outlined text-[18px]">done_all</span>
                <?= e(lang('mark_all_present')) ?>
            </button>
            <button type="button" class="courses-bulk-btn courses-bulk-btn--reject" data-attendance-action="all-absent"<?= $sessionLocked ? ' disabled' : '' ?>>
                <span class="material-symbols-outlined text-[18px]">block</span>
                <?= e(lang('mark_all_absent')) ?>
            </button>
            <button type="button" class="courses-bulk-btn" data-attendance-action="all-excused"<?= $sessionLocked ? ' disabled' : '' ?>>
                <span class="material-symbols-outlined text-[18px]">event_busy</span>
                <?= e(lang('mark_all_excused')) ?>
            </button>
        </div>

        <div class="courses-table-container">
            <table class="courses-table courses-table--auto">
                <thead>
                    <tr>
                        <th><?= e(lang('attendance_status')) ?></th>
                        <th><?= e(lang('participant_name')) ?></th>
                        <th><?= e(lang('email')) ?></th>
                        <th><?= e(lang('attendance_rate')) ?></th>
                        <th><?= e(lang('cert_eligibility')) ?></th>
                        <th class="courses-th-actions"><?= e(lang('actions')) ?></th>
                    </tr>
                </thead>
                <tbody>
                    <?php if (empty($participants)): ?>
                    <tr>
                        <td colspan="6" class="courses-empty">
                            <span class="material-symbols-outlined">group_off</span>
                            <p><?= e(lang('no_participants')) ?></p>
                        </td>
                    </tr>
                    <?php else: foreach ($participants as $p):
                        $pid = (int) $p['id'];
                        $rowStatus = \CTDHR\Models\Attendance::rowStatus($attendance[$pid] ?? []);
                        $breakdown = $participantRateBreakdowns[$pid] ?? ['present' => 0, 'total' => 0, 'rate' => 0.0];
                        $elig = $participantEligibility[$pid] ?? ['eligible' => false, 'rate' => 0, 'total' => 0];
                        $rate = (float) ($breakdown['rate'] ?? $participantRates[$pid] ?? 0);
                        $rateHint = lang('attendance_rate_hint', [
                            'present' => (string) ($breakdown['present'] ?? 0),
                            'total' => (string) ($breakdown['total'] ?? 0),
                            'rate' => (string) $rate,
                        ]);
                    ?>
                    <tr class="attendance-row--<?= e($rowStatus) ?>">
                        <td>
                            <div class="attendance-status-pills<?= $sessionLocked ? ' is-disabled' : '' ?>" role="radiogroup" aria-label="<?= e(lang('attendance_status')) ?>">
                                <?php foreach (['present' => 'check_circle', 'absent' => 'cancel', 'excused' => 'event_busy'] as $st => $stIcon): ?>
                                <input type="radio"
                                       name="status[<?= $pid ?>]"
                                       value="<?= e($st) ?>"
                                       id="att-status-<?= $pid ?>-<?= e($st) ?>"
                                       class="attendance-status-pill__input"
                                       <?= $rowStatus === $st ? 'checked' : '' ?>
                                       <?= $sessionLocked ? 'disabled' : '' ?>>
                                <label for="att-status-<?= $pid ?>-<?= e($st) ?>"
                                       class="attendance-status-pill attendance-status-pill--<?= e($st) ?><?= $rowStatus === $st ? ' is-active' : '' ?>"
                                       data-status="<?= e($st) ?>">
                                    <span class="material-symbols-outlined" aria-hidden="true"><?= e($stIcon) ?></span>
                                    <?= e(lang('attendance_' . $st)) ?>
                                </label>
                                <?php endforeach; ?>
                            </div>
                        </td>
                        <td><span class="courses-td-name"><?= e(localized($p, 'full_name')) ?></span></td>
                        <td class="courses-td-muted"><?= e($p['email']) ?></td>
                        <td>
                            <span class="attendance-rate-badge<?= $rate >= $attendanceThreshold ? ' is-good' : ($rate >= 50 ? ' is-mid' : ' is-low') ?>" title="<?= e($rateHint) ?>"><?= $rate ?>%</span>
                            <?php if (($breakdown['total'] ?? 0) > 0): ?>
                            <span class="attendance-rate-meta"><?= (int) $breakdown['present'] ?>/<?= (int) $breakdown['total'] ?></span>
                            <?php endif; ?>
                        </td>
                        <td>
                            <?php if (($elig['total'] ?? 0) === 0): ?>
                            <span class="courses-badge courses-badge--pending-email"><?= e(lang('ineligible_no_data')) ?></span>
                            <?php elseif (!empty($elig['eligible'])): ?>
                            <span class="courses-badge courses-badge--sent"><?= e(lang('eligible')) ?></span>
                            <?php else: ?>
                            <span class="courses-badge courses-badge--pending-email"><?= e(lang('at_risk')) ?></span>
                            <?php endif; ?>
                        </td>
                        <td class="courses-td-actions">
                            <button type="button" class="courses-action" data-history-url="<?= e(url('admin/attendance/' . $course['id'] . '/participant/' . $pid . '/history')) ?>" title="<?= e(lang('attendance_history')) ?>">
                                <span class="material-symbols-outlined">timeline</span>
                            </button>
                        </td>
                    </tr>
                    <?php endforeach; endif; ?>
                </tbody>
            </table>
        </div>
        <div class="courses-form-footer">
