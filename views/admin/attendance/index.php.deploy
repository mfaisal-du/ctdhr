    <div class="courses-table-container">
        <table class="courses-table courses-table--attendance">
            <thead>
                <tr>
                    <th><?= e(lang('course_title')) ?></th>
                    <th><?= e(lang('status')) ?></th>
                    <th><?= e(lang('dates')) ?></th>
                    <th><?= e(lang('participants')) ?></th>
                    <th><?= e(lang('session_progress')) ?></th>
                    <th><?= e(lang('attendance_rate')) ?></th>
                    <th class="courses-th-actions"><?= e(lang('actions')) ?></th>
                </tr>
            </thead>
            <tbody>
                <?php if (empty($result['items'])): ?>
                <tr>
                    <td colspan="7" class="courses-empty">
                        <span class="material-symbols-outlined">event_busy</span>
                        <p><?= e(lang('no_courses_attendance')) ?></p>
                    </td>
                </tr>
                <?php else: foreach ($result['items'] as $c):
                    $status = (string) ($c['status'] ?? '');
                    $marking = (string) ($c['marking_status'] ?? 'not_started');
                    $approved = (int) ($c['approved_count'] ?? 0);
                    $sessionsMarked = (int) ($c['sessions_marked'] ?? 0);
                    $totalSessions = (int) ($c['total_sessions'] ?? 0);
                    $rate = (float) ($c['attendance_rate'] ?? 0);
                    $progress = (int) ($c['session_progress'] ?? 0);
                ?>
                <tr>
                    <td class="courses-td-title">
                        <a href="<?= e(url('admin/attendance/' . $c['id'])) ?>" class="courses-link-title"><?= e(localized($c, 'title')) ?></a>
                        <?php if ($sessionsMarked > 0): ?>
                        <span class="courses-link-meta"><?= e(lang('sessions_marked', ['count' => (string) $sessionsMarked])) ?></span>
                        <?php endif; ?>
                    </td>
                    <td>
                        <span class="courses-badge courses-badge--<?= e(str_replace('_', '-', $status)) ?>"><?= e(course_status_label($status)) ?></span>
                    </td>
                    <td class="courses-td-date">
                        <?= e(format_date($c['start_date'])) ?>
                        <?php if (!empty($c['end_date'])): ?>
                        <span class="courses-td-muted"> – <?= e(format_date($c['end_date'])) ?></span>
                        <?php endif; ?>
                    </td>
                    <td>
                        <span class="admin-stat-pill admin-stat-pill--approved"><?= $approved ?> <?= e(lang('approved')) ?></span>
                    </td>
                    <td>
                        <div class="attendance-progress-cell">
                            <div class="attendance-progress-bar" role="progressbar" aria-valuenow="<?= $progress ?>" aria-valuemin="0" aria-valuemax="100">
                                <span class="attendance-progress-fill" style="width: <?= $progress ?>%"></span>
                            </div>
                            <span class="attendance-progress-label"><?= $sessionsMarked ?>/<?= max($totalSessions, 1) ?> <?= e(lang('sessions_short')) ?></span>
                        </div>
                    </td>
                    <td>
                        <span class="attendance-rate-badge<?= $rate >= 75 ? ' is-good' : ($rate >= 50 ? ' is-mid' : ' is-low') ?>"><?= $rate ?>%</span>
                    </td>
                    <td class="courses-td-actions">
                        <div class="courses-actions-row">
                            <span class="courses-badge courses-badge--marking-<?= e(str_replace('_', '-', $marking)) ?>"><?= e(lang('marking_' . $marking)) ?></span>
                            <a href="<?= e(url('admin/attendance/' . $c['id'])) ?>" class="courses-action courses-action--approve" title="<?= e(lang('mark_attendance')) ?>">
                                <span class="material-symbols-outlined">edit_square</span>
                            </a>
                            <?php if ($marking === 'complete'): ?>
                            <a href="<?= e(url('admin/certificates/generate?course_id=' . $c['id'])) ?>" class="courses-action" title="<?= e(lang('generate_certificates')) ?>">
                                <span class="material-symbols-outlined">verified</span>
                            </a>
                            <?php endif; ?>
                            <a href="<?= e(url('admin/audit?action=attendance.mark&search=course')) ?>" class="courses-action" title="<?= e(lang('audit_log')) ?>">
                                <span class="material-symbols-outlined">history</span>
                            </a>
                        </div>
                    </td>
                </tr>
                <?php endforeach; endif; ?>
            </tbody>
