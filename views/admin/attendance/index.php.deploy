        </div>
    </div>
    <?php endforeach; ?>
</div>

<div class="courses-card">
    <div class="admin-toolbar admin-toolbar--attendance">
        <a href="<?= e(url('admin/attendance/' . $course['id'] . '/export')) ?>" class="courses-btn-secondary courses-btn-secondary--sm">
