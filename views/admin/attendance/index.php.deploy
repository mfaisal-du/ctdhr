            </label>
        </form>
        <?php
        $riskParams = ['session' => $sessionDate];
        $riskParams['risk'] = ($riskFilter === 'at_risk') ? '' : 'at_risk';
        ?>
        <a href="?<?= e(http_build_query($riskParams)) ?>" class="courses-btn-secondary courses-btn-secondary--sm<?= $riskFilter === 'at_risk' ? ' is-active' : '' ?>">
            <span class="material-symbols-outlined">warning</span><?= e(lang('at_risk_filter')) ?>
        </a>
    </div>

    <?php if ($sessionLocked): ?>
    <div class="admin-lock-banner">
        <span class="material-symbols-outlined">lock</span>
        <?= e(lang('session_locked_notice')) ?>
