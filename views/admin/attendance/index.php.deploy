            <button type="submit" class="courses-btn-save">
                <span class="material-symbols-outlined courses-btn-icon text-[18px]">save</span>
                <?= e(lang('save_attendance')) ?>
            </button>
            <?php endif; ?>
        </div>
    </form>
</div>

<div id="participantTimelineModal"
     class="admin-overlay-modal admin-overlay-modal--timeline"
     data-label-eligible="<?= e(lang('eligible')) ?>"
     data-label-at-risk="<?= e(lang('at_risk')) ?>"
     data-label-events="<?= e(lang('timeline_events_count')) ?>"
