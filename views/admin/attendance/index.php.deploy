]);
?>

<a href="<?= e(url('admin/attendance')) ?>" class="courses-back-link">
    <span class="material-symbols-outlined text-[18px]">arrow_back</span>
    <?= e(lang('back_to_attendance')) ?>
</a>

<?php
$sessionKpiValue = $currentSession !== null
    ? attendance_session_kpi_value($currentSession)
    : lang('session_number', ['n' => '1']);
$sessionKpiTopic = ($currentSession['detail'] ?? '') !== '' ? (string) $currentSession['detail'] : '';
?>
<div class="courses-kpi-grid courses-kpi-grid--compact" aria-label="<?= e(lang('mark_attendance')) ?>">
    <?php foreach ([
        ['blue', 'group', lang('participants'), (string) count($participants), ''],
        ['green', 'check_circle', lang('present'), (string) $sessionPresentCount, 'data-live-present'],
        ['gold', 'person_off', lang('absent'), (string) $sessionAbsentCount, 'data-live-absent'],
        ['sky', 'event', $sessionKpiTopic !== '' ? $sessionKpiTopic : lang('session'), $sessionKpiValue, 'is-text'],
    ] as [$theme, $icon, $label, $val, $valueAttr]): ?>
    <div class="courses-kpi courses-kpi--<?= e($theme) ?>">
