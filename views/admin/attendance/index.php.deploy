<?php declare(strict_types=1);

$result = $result ?? ['items' => [], 'page' => 1, 'pages' => 1, 'total' => 0];
$filters = $filters ?? [];
$stats = $stats ?? [];
$participantRates = $participantRates ?? [];
$participantRateBreakdowns = $participantRateBreakdowns ?? [];
$sessionEntries = $sessionEntries ?? [];
$currentSession = $currentSession ?? null;
$reminders = $reminders ?? [];
$attendanceThreshold = (int) ($attendanceThreshold ?? 75);
$participantEligibility = $participantEligibility ?? [];
$sessionLocked = (bool) ($sessionLocked ?? false);
$riskFilter = (string) ($riskFilter ?? '');
$sessionPresentCount = (int) ($sessionPresentCount ?? 0);
$sessionAbsentCount = (int) ($sessionAbsentCount ?? 0);

$hasActiveFilters = !empty($filters['search']) || !empty($filters['status']) || !empty($filters['marking']) || (($filters['sort'] ?? 'start_date') !== 'start_date');
$filterQuery = static function (array $extra = []) use ($filters): string {
    return http_build_query(array_filter(array_merge($filters, $extra), static fn ($v) => $v !== '' && $v !== null));
};

?>
<div class="admin-module-page admin-module-page--listing">
<?php if (empty($course)): ?>
<?php
admin_page_header([
    'icon' => 'assignment_turned_in',
    'title' => lang('attendance'),
    'subtitle' => lang('attendance_manage_subtitle'),
    'accent' => 'green',
    'breadcrumbs' => [
        ['label' => lang('admin_dashboard'), 'href' => url('admin')],
        ['label' => lang('attendance')],
    ],
]);
?>

<div class="courses-kpi-grid" aria-label="<?= e(lang('attendance')) ?>">
    <?php foreach ([
        ['blue', 'menu_book', lang('courses'), (int) ($stats['courses'] ?? $result['total'] ?? 0)],
        ['green', 'group', lang('approved'), (int) ($stats['approved'] ?? 0)],
        ['sky', 'check_circle', lang('present'), (int) ($stats['present'] ?? 0)],
        ['gold', 'event_available', lang('sessions_marked_label'), (int) ($stats['sessions_marked'] ?? 0)],
    ] as [$theme, $icon, $label, $val]): ?>
    <div class="courses-kpi courses-kpi--<?= e($theme) ?>">
        <div class="courses-kpi-icon"><span class="material-symbols-outlined"><?= e($icon) ?></span></div>
        <div class="courses-kpi-body">
            <span class="courses-kpi-value"><?= (int) $val ?></span>
            <span class="courses-kpi-label"><?= e($label) ?></span>
        </div>
    </div>
    <?php endforeach; ?>
</div>

<?php if (!empty($reminders)): ?>
<div class="admin-reminder-banner" role="status">
    <span class="material-symbols-outlined">notification_important</span>
    <div>
        <strong><?= e(lang('session_marking_reminders')) ?></strong>
        <ul class="admin-reminder-list">
            <?php foreach (array_slice($reminders, 0, 5) as $rem): ?>
            <li>
                <a href="<?= e(url('admin/attendance/' . (int) $rem['course_id'])) ?>"><?= e(localized($rem, 'title')) ?></a>
                — <?= (int) ($rem['sessions_marked'] ?? 0) ?>/<?= max((int) ($rem['total_sessions'] ?? 0), 1) ?> <?= e(lang('sessions_short')) ?>
            </li>
            <?php endforeach; ?>
        </ul>
    </div>
</div>
<?php endif; ?>

<div class="courses-card">
    <div class="admin-quick-filters admin-quick-filters--green">
        <p class="admin-quick-filters__label">
            <span class="material-symbols-outlined" aria-hidden="true">fact_check</span>
            <?= e(lang('marking_status')) ?>
        </p>
        <nav class="admin-quick-filters__track" aria-label="<?= e(lang('marking_status')) ?>">
            <?php foreach ([
                ['', 'grid_view', lang('filter_all_short')],
                ['not_started', 'hourglass_empty', lang('marking_not_started')],
                ['in_progress', 'pending_actions', lang('marking_in_progress')],
                ['complete', 'task_alt', lang('marking_complete')],
            ] as [$mkVal, $mkIcon, $mkLabel]): ?>
            <a href="?<?= e($filterQuery(['marking' => $mkVal, 'page' => 1])) ?>"
               class="admin-quick-filter<?= ($filters['marking'] ?? '') === $mkVal ? ' is-active' : '' ?>"
               <?= ($filters['marking'] ?? '') === $mkVal ? 'aria-current="page"' : '' ?>>
                <span class="material-symbols-outlined" aria-hidden="true"><?= e($mkIcon) ?></span>
                <?= e($mkLabel) ?>
            </a>
            <?php endforeach; ?>
        </nav>
    </div>

    <form method="GET" action="<?= e(url('admin/attendance')) ?>" class="courses-filters" data-filter-persist="attendance-list">
        <div class="courses-search">
            <span class="material-symbols-outlined">search</span>
            <input type="search" name="search" value="<?= e($filters['search'] ?? '') ?>" placeholder="<?= e(lang('attendance_search_placeholder')) ?>" class="courses-search-input" autocomplete="off">
        </div>
        <div class="courses-filter-group">
            <div class="admin-select-wrap admin-select-wrap--sm admin-select-wrap--filter">
                <select name="status" class="admin-form-select courses-filter-select" aria-label="<?= e(lang('status')) ?>">
                    <option value=""><?= e(lang('all_statuses')) ?></option>
                    <?php foreach (['scheduled', 'in_progress', 'completed'] as $st): ?>
                    <option value="<?= e($st) ?>" <?= ($filters['status'] ?? '') === $st ? 'selected' : '' ?>><?= e(course_status_label($st)) ?></option>
                    <?php endforeach; ?>
                </select>
            </div>
            <div class="admin-select-wrap admin-select-wrap--sm admin-select-wrap--filter">
                <select name="sort" class="admin-form-select courses-filter-select" aria-label="<?= e(lang('sort_by')) ?>">
                    <option value="start_date" <?= ($filters['sort'] ?? 'start_date') === 'start_date' ? 'selected' : '' ?>><?= e(lang('sort_start_date')) ?></option>
                    <option value="title" <?= ($filters['sort'] ?? '') === 'title' ? 'selected' : '' ?>><?= e(lang('sort_title')) ?></option>
                    <option value="approved" <?= ($filters['sort'] ?? '') === 'approved' ? 'selected' : '' ?>><?= e(lang('sort_participants')) ?></option>
                    <option value="sessions" <?= ($filters['sort'] ?? '') === 'sessions' ? 'selected' : '' ?>><?= e(lang('sort_sessions_marked')) ?></option>
                </select>
            </div>
            <input type="hidden" name="marking" value="<?= e($filters['marking'] ?? '') ?>">
            <button type="submit" class="courses-btn-filter">
                <span class="material-symbols-outlined">filter_list</span>
                <?= e(lang('filter')) ?>
            </button>
            <?php if ($hasActiveFilters): ?>
            <a href="<?= e(url('admin/attendance')) ?>" class="courses-clear"><?= e(lang('clear_filters')) ?></a>
            <?php endif; ?>
        </div>
    </form>

    <div class="admin-results-bar">
        <span><?= e(str_replace([':shown', ':total'], [(string) count($result['items']), (string) ($result['total'] ?? 0)], lang('results_count'))) ?></span>
        <div class="admin-results-actions">
            <a href="<?= e(url('admin/attendance/export') . '?' . $filterQuery()) ?>" class="courses-btn-secondary courses-btn-secondary--sm">
                <span class="material-symbols-outlined">download</span><?= e(lang('export_csv')) ?>
