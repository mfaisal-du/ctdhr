            <span class="courses-kpi-value<?= $valueAttr === 'is-text' ? ' courses-kpi-value--text' : '' ?>"<?= in_array($valueAttr, ['data-live-present', 'data-live-absent'], true) ? ' ' . $valueAttr . '="' . e($val) . '"' : '' ?>><?= e($val) ?></span>
