        <a href="<?= e(url('admin/attendance/' . $course['id'] . '/print?session=' . urlencode($sessionDate))) ?>" class="courses-btn-secondary courses-btn-secondary--sm" target="_blank" rel="noopener">
            <span class="material-symbols-outlined">print</span><?= e(lang('print_sheet')) ?>
