<?php declare(strict_types=1);

$result = $result ?? ['items' => [], 'page' => 1, 'pages' => 1, 'total' => 0];
$stats = $stats ?? ['pending' => 0, 'approved_week' => 0, 'rejected_week' => 0, 'oldest_wait_days' => null];
$filters = $filters ?? ['search' => '', 'waiting' => ''];
$tab = ($tab ?? 'pending') === 'history' ? 'history' : 'pending';
$highlightId = (int) ($highlightId ?? 0);

$oldestKpi = ($stats['oldest_wait_days'] ?? null) !== null
    ? pending_wait_label((int) $stats['oldest_wait_days'])
    : '—';

$queryParams = static function (array $extra = []) use ($tab, $filters): string {
    $params = array_merge([
        'tab' => $tab !== 'pending' ? $tab : null,
        'search' => $filters['search'] ?? '',
        'waiting' => $filters['waiting'] ?? '',
    ], $extra);

    return http_build_query(array_filter($params, static fn ($value): bool => $value !== null && $value !== ''));
};

$exportBtn = '<a href="' . e(url('admin/users/pending/export?' . $queryParams())) . '" class="courses-btn-secondary courses-btn-secondary--sm">'
    . '<span class="material-symbols-outlined">download</span>'
    . e(lang('export_csv'))
    . '</a>';
?>

<div class="admin-module-page" x-data="pendingExternalModals()">
<?php
admin_page_header([
    'icon' => 'person_add',
    'title' => lang('pending_external_accounts'),
    'subtitle' => lang('pending_external_subtitle'),
    'accent' => 'gold',
    'actions' => $tab === 'pending' ? $exportBtn : '',
    'breadcrumbs' => [
        ['label' => lang('admin_dashboard'), 'href' => url('admin')],
        ['label' => lang('users'), 'href' => url('admin/users')],
        ['label' => lang('pending_external_accounts')],
    ],
]);
?>

<div class="courses-kpi-grid">
    <?php foreach ([
        ['gold', 'pending', lang('status_pending'), (int) ($stats['pending'] ?? 0)],
        ['green', 'check_circle', lang('external_approved_this_week'), (int) ($stats['approved_week'] ?? 0)],
        ['sky', 'cancel', lang('external_rejected_this_week'), (int) ($stats['rejected_week'] ?? 0)],
    ] as [$theme, $icon, $label, $val]): ?>
    <div class="courses-kpi courses-kpi--<?= e($theme) ?>">
        <div class="courses-kpi-icon"><span class="material-symbols-outlined"><?= e($icon) ?></span></div>
        <div class="courses-kpi-body">
            <span class="courses-kpi-value"><?= (int) $val ?></span>
            <span class="courses-kpi-label"><?= e($label) ?></span>
        </div>
    </div>
    <?php endforeach; ?>
    <div class="courses-kpi courses-kpi--blue">
        <div class="courses-kpi-icon"><span class="material-symbols-outlined">schedule</span></div>
        <div class="courses-kpi-body">
            <span class="courses-kpi-value text-headline-sm"><?= e($oldestKpi) ?></span>
            <span class="courses-kpi-label"><?= e(lang('external_oldest_pending')) ?></span>
        </div>
    </div>
</div>

<div class="admin-page-tabs">
    <a href="<?= e(url('admin/users/pending?' . $queryParams(['tab' => null, 'page' => null]))) ?>"
       class="admin-page-tab<?= $tab === 'pending' ? ' admin-page-tab--active' : '' ?>">
        <span class="material-symbols-outlined text-[18px]">inbox</span>
