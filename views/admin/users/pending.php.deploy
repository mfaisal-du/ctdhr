                <span class="material-symbols-outlined text-[20px]">close</span>
            </button>
        </div>
        <form x-ref="rejectForm" method="POST" action="#" class="admin-modal-form">
            <?= csrf_field() ?>
            <div class="admin-modal-body space-y-unit-md">
                <div class="flex flex-wrap gap-2">
                    <?php foreach ([
                        'rejection_template_incomplete',
                        'rejection_template_duplicate',
                        'rejection_template_ineligible',
                    ] as $templateKey): ?>
                    <button type="button"
                            class="admin-reason-chip"
                            @click="rejectionReason = <?= json_encode(lang($templateKey), JSON_UNESCAPED_UNICODE) ?>">
                        <?= e(lang($templateKey)) ?>
                    </button>
                    <?php endforeach; ?>
                </div>
                <label class="courses-label" for="rejection_reason"><?= e(lang('rejection_reason')) ?></label>
                <textarea id="rejection_reason" name="rejection_reason" x-model="rejectionReason" required rows="3" class="courses-input courses-textarea" placeholder="<?= e(lang('rejection_reason_placeholder')) ?>"></textarea>
            </div>
            <div class="admin-modal-footer">
                <button type="button" class="courses-btn-ghost" @click="rejectId = null"><?= e(lang('cancel')) ?></button>
                <button type="submit" class="courses-bulk-btn courses-bulk-btn--reject">
                    <span class="material-symbols-outlined text-[18px]">cancel</span>
                    <?= e(lang('reject')) ?>
