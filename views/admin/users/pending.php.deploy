<?php $externalApproveForms = ''; ?>

<?php if ($tab === 'pending'): ?>
<div class="courses-card">
    <form method="GET" action="<?= e(url('admin/users/pending')) ?>" class="courses-filters">
        <div class="courses-search">
            <span class="material-symbols-outlined">search</span>
