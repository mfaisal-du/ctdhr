    <a href="<?= e(url('admin/users/pending?' . $queryParams(['tab' => 'history', 'page' => null, 'search' => null, 'waiting' => null]))) ?>"
       class="admin-page-tab<?= $tab === 'history' ? ' admin-page-tab--active' : '' ?>">
