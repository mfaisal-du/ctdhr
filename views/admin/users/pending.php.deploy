            </div>
        </form>
    </div>
</div>

<script>
document.addEventListener('alpine:init', function () {
    Alpine.data('pendingExternalModals', function () {
        return {
            rejectId: null,
            rejectName: '',
            rejectionReason: '',
            approveId: null,
            approveName: '',
            approveEmail: '',
            detailOpen: false,
            detailUser: {},
            approveBaseUrl: <?= json_encode(url('admin/users')) ?>,
            openDetail: function (btn) {
                this.detailUser = {
                    id: parseInt(btn.dataset.userId, 10) || null,
                    name: btn.dataset.userName || '',
                    email: btn.dataset.userEmail || '',
                    org: btn.dataset.userOrg || '',
                    phone: btn.dataset.userPhone || '',
                    registered: btn.dataset.userRegistered || '',
                    verified: btn.dataset.userVerified || '',
                    wait: btn.dataset.userWait || '',
                };
                this.detailOpen = true;
            },
            openApprove: function (btn) {
                this.approveId = parseInt(btn.dataset.userId, 10) || null;
                this.approveName = btn.dataset.userName || '';
                this.approveEmail = btn.dataset.userEmail || '';
            },
            openReject: function (btn) {
                this.rejectId = parseInt(btn.dataset.userId, 10) || null;
                this.rejectName = btn.dataset.userName || '';
                this.rejectionReason = '';
                this.syncRejectFormAction();
            },
            openRejectFromDetail: function () {
                if (!this.detailUser.id) {
                    return;
                }
                this.rejectId = this.detailUser.id;
                this.rejectName = this.detailUser.name || '';
                this.rejectionReason = '';
                this.syncRejectFormAction();
            },
            syncRejectFormAction: function () {
                var form = this.$refs.rejectForm;
                if (!form || !this.rejectId) {
                    return;
                }
                form.action = this.approveBaseUrl + '/' + this.rejectId + '/reject';
            },
        };
    });
});

<?php if ($highlightId > 0 && $tab === 'pending'): ?>
document.addEventListener('DOMContentLoaded', function () {
    var row = document.getElementById('external-user-<?= $highlightId ?>');
    if (row) {
        row.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
});
<?php endif; ?>
</script>
</div>