                <dt class="text-label-sm text-on-surface-variant uppercase tracking-wide mb-1"><?= e(lang('role')) ?></dt>
                <dd class="text-on-surface font-label-md"><?= e(role_label((string) ($user['role'] ?? 'staff'))) ?></dd>
