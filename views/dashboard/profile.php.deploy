            <div>
                <dt class="text-label-sm text-on-surface-variant uppercase tracking-wide mb-1"><?= e(lang('department')) ?></dt>
                <dd class="text-on-surface font-label-md"><?= e(localized($user, 'department') ?: '—') ?></dd>
