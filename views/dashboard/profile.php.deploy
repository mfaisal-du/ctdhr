                <dd class="text-on-surface font-label-md"><?= e((string) ($user['employee_id'] ?? '—')) ?></dd>
            </div>
            <?php endif; ?>
            <?php if (!empty($user['last_login_at'])): ?>
            <div class="md:col-span-2">
                <dt class="text-label-sm text-on-surface-variant uppercase tracking-wide mb-1"><?= e(lang('last_login')) ?></dt>
