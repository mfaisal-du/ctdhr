            <div>
                <dt class="text-label-sm text-on-surface-variant uppercase tracking-wide mb-1"><?= e(lang('college')) ?></dt>
                <dd class="text-on-surface font-label-md"><?= e(localized($user, 'college') ?: '—') ?></dd>
