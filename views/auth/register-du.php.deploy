                <label for="full_name" class="auth-field-label"><?= e(lang('full_name')) ?></label>
                <input type="text" id="full_name" name="full_name" value="<?= e(old('full_name')) ?>" required autocomplete="name" class="stitch-input">
            </div>

            <div class="auth-field-group" :class="emailInvalid && 'auth-field-group--invalid'">
                <label for="email" class="auth-field-label"><?= e(lang('email')) ?></label>
                <div class="relative auth-field-input" x-ref="emailWrap">
                    <span class="material-symbols-outlined absolute top-1/2 -translate-y-1/2 <?= is_rtl() ? 'right-3' : 'left-3' ?> text-outline text-sm">mail</span>
                    <input type="email"
                           id="email"
