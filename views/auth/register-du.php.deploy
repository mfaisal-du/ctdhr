            <div>
                <label for="password" class="auth-field-label"><?= e(lang('password')) ?></label>
                <input type="password"
                       id="password"
                       name="password"
                       x-model="password"
                       @input="touched.password = true"
                       required
                       minlength="8"
                       autocomplete="new-password"
                       class="stitch-input">
                <p class="auth-field-hint"><?= e(lang('password_hint')) ?></p>
