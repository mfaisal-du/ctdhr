                $show = 'duEmailBlocked';
                $message = lang('external_du_email_not_allowed');
                require view_path('auth/components/auth-field-error.php');
                $show = 'emailInvalid && !duEmailBlocked';
                $message = lang('external_email_invalid');
                require view_path('auth/components/auth-field-error.php');
