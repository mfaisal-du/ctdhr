            <div>
                <label for="password" class="auth-field-label"><?= e(lang('password')) ?></label>
                <input type="password"
                       id="password"
                       name="password"
                       x-model="password"
                       @input="touched.password = true"
                       required
                       minlength="8"
                       autocomplete="new-password"
                       class="stitch-input">
                <p class="auth-field-hint"><?= e(lang('password_hint')) ?></p>
            </div>

            <div class="auth-field-group" :class="passwordMismatch && 'auth-field-group--invalid'">
                <label for="confirm_password" class="auth-field-label"><?= e(lang('confirm_password')) ?></label>
                <div class="auth-field-input" x-ref="confirmWrap">
                    <input type="password"
