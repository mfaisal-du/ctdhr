            </div>

            <div>
                <label for="phone" class="auth-field-label">
                    <?= e(lang('phone')) ?> <span class="auth-field-optional">(<?= e(lang('optional')) ?>)</span>
                </label>
                <input type="tel" id="phone" name="phone" value="<?= e(old('phone')) ?>" autocomplete="tel" class="stitch-input">
