</div>

<script>
function registerExternalForm() {
    const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    const duEmailPattern = /@du\.edu\.om$/i;

    return {
        email: <?= json_encode(old('email', ''), JSON_UNESCAPED_UNICODE) ?>,
        password: '',
        confirmPassword: '',
        touched: {
            email: <?= json_encode(old('email', '') !== '') ?>,
            password: false,
            confirmPassword: false
        },
        get emailInvalid() {
            if (!this.touched.email || !this.email) return false;
            return !emailPattern.test(this.email.trim());
        },
        get duEmailBlocked() {
            if (!this.touched.email || !this.email) return false;
            return duEmailPattern.test(this.email.trim());
        },
        get passwordMismatch() {
            if (!this.touched.confirmPassword || !this.confirmPassword) return false;
            return this.password !== this.confirmPassword;
        },
        canSubmit() {
            const value = this.email.trim();
            if (!value || !emailPattern.test(value) || duEmailPattern.test(value)) return false;
            if (this.password.length < 8) return false;
            if (this.password !== this.confirmPassword) return false;
            return true;
        },
        shakeField(el) {
            if (!el) return;
            el.classList.remove('auth-field-input--shake');
            void el.offsetWidth;
            el.classList.add('auth-field-input--shake');
        }
    };
}
</script>
<?php
$content = ob_get_clean();
$pageTitle = lang('register_external');
$authCardWidth = 'lg';
require view_path('layouts/auth.php');