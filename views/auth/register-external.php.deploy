                           name="confirm_password"
                           x-model="confirmPassword"
                           @input="touched.confirmPassword = true"
                           @blur="touched.confirmPassword = true; if (passwordMismatch) shakeField($refs.confirmWrap)"
                           required
                           minlength="8"
                           autocomplete="new-password"
                           :class="passwordMismatch ? 'stitch-input stitch-input--error' : 'stitch-input'"
