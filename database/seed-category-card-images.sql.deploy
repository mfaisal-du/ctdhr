-- Demo category card backgrounds (local WebP files under public/assets/uploads/categories).
-- Generate files with: powershell -ExecutionPolicy Bypass -File database/seed-category-card-images.ps1

USE ctdhr_portal;

UPDATE course_categories SET card_image_path = 'uploads/categories/category-1-information-technology.webp' WHERE slug = 'information-technology';
