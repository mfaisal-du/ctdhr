UPDATE course_categories SET card_image_path = 'uploads/categories/category-5-leadership-management.webp' WHERE slug = 'leadership-management';
UPDATE course_categories SET card_image_path = 'uploads/categories/category-6-health-safety.webp' WHERE slug = 'health-safety';
UPDATE course_categories SET card_image_path = 'uploads/categories/category-7-digital-literacy.webp' WHERE slug = 'digital-literacy';
