        $isAr = $locale === 'ar';
        $name = (string) ($user['full_name_en'] ?? $user['full_name_ar'] ?? 'Participant');
        $email = (string) ($user['email'] ?? '');

        $subject = $isAr
            ? 'تم اعتماد حسابك - بوابة CTDHR'
            : 'Your Account Has Been Approved - CTDHR Portal';

