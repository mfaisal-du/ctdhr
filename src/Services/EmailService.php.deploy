        return $this->send($email, 'Test Recipient', $subject, $html, $altBody);
    }

    /**
     * @param array<string, mixed> $user
     * @param array<string, mixed> $course
     * @param array<string, mixed> $application
     */
    public function sendApplicationConfirmation(array $user, array $course, array $application): bool
    {
        $locale = $_SESSION['locale'] ?? config('locale', 'en');
        $isAr = $locale === 'ar';
        $name = (string) ($user['full_name_en'] ?? $user['full_name_ar'] ?? 'Participant');
        $email = (string) ($user['email'] ?? '');
        $courseTitle = $isAr
            ? (string) ($course['title_ar'] ?? $course['title_en'] ?? '')
            : (string) ($course['title_en'] ?? '');

        $subject = $isAr
            ? 'تأكيد تقديم الطلب - بوابة CTDHR'
            : 'Application Confirmation - CTDHR Portal';

        $greeting = $isAr ? 'مرحباً' : 'Hello';
        $intro = $isAr
            ? 'تم استلام طلبك للتسجيل في الدورة التالية:'
            : 'We have received your application for the following course:';
        $statusNote = $isAr
            ? 'حالة الطلب: قيد المراجعة'
            : 'Application status: Pending review';
        $dashboardNote = $isAr
            ? 'يمكنك متابعة حالة طلبك من لوحة التحكم.'
            : 'You can track your application status from your dashboard.';
        $dashboardUrl = url('dashboard/applications');

        $html = $this->buildEmailTemplate(
            $greeting,
            $name,
            $intro,
            '<p style="font-size:18px;font-weight:600;color:#1E5AA8;margin:16px 0;">' . htmlspecialchars($courseTitle) . '</p>'
            . '<p style="color:#666;">' . htmlspecialchars($statusNote) . '</p>'
            . '<p style="margin-top:16px;"><a href="' . htmlspecialchars($dashboardUrl) . '" style="color:#1E5AA8;">' . htmlspecialchars($dashboardNote) . '</a></p>'
        );

        $altBody = "{$greeting} {$name},\n\n{$intro}\n\n{$courseTitle}\n\n{$statusNote}\n\n{$dashboardUrl}";

        return $this->send($email, $name, $subject, $html, $altBody);
    }

    /**
     * @param array<string, mixed> $user
     * @param array<string, mixed> $course
     * @param array<string, mixed> $application
     */
    public function sendApplicationStatusChange(
        array $user,
        array $course,
        array $application,
        string $oldStatus,
        string $newStatus
    ): bool {
        $locale = $_SESSION['locale'] ?? config('locale', 'en');
        $isAr = $locale === 'ar';
        $name = (string) ($user['full_name_en'] ?? $user['full_name_ar'] ?? 'Participant');
        $email = (string) ($user['email'] ?? '');
        $courseTitle = $isAr
            ? (string) ($course['title_ar'] ?? $course['title_en'] ?? '')
            : (string) ($course['title_en'] ?? '');

        $statusLabels = [
            'pending' => $isAr ? 'قيد الانتظار' : 'Pending',
            'approved' => $isAr ? 'مقبول' : 'Approved',
            'rejected' => $isAr ? 'مرفوض' : 'Rejected',
            'cancelled' => $isAr ? 'ملغى' : 'Cancelled',
            'waitlisted' => $isAr ? 'قائمة الانتظار' : 'Waitlisted',
        ];

        $newLabel = $statusLabels[$newStatus] ?? $newStatus;

        $subject = $isAr
            ? 'تحديث حالة الطلب - بوابة CTDHR'
            : 'Application Status Update - CTDHR Portal';

        $greeting = $isAr ? 'مرحباً' : 'Hello';
        $intro = $isAr
            ? 'تم تحديث حالة طلبك للدورة:'
            : 'Your application status has been updated for:';
        $statusLine = $isAr
            ? 'الحالة الجديدة: <strong>' . htmlspecialchars($newLabel) . '</strong>'
            : 'New status: <strong>' . htmlspecialchars($newLabel) . '</strong>';
        $dashboardUrl = url('dashboard/applications');
        $linkNote = $isAr
            ? '<p style="margin-top:16px;"><a href="' . htmlspecialchars($dashboardUrl) . '">عرض طلباتي</a></p>'
            : '<p style="margin-top:16px;"><a href="' . htmlspecialchars($dashboardUrl) . '">View my applications</a></p>';

        $html = $this->buildEmailTemplate(
            $greeting,
            $name,
            $intro,
            '<p style="font-size:18px;font-weight:600;color:#1E5AA8;margin:16px 0;">' . htmlspecialchars($courseTitle) . '</p>'
            . '<p>' . $statusLine . '</p>'
            . $linkNote
        );

        $altBody = "{$greeting} {$name},\n\n{$intro}\n\n{$courseTitle}\n\nNew status: {$newLabel}\n\n{$dashboardUrl}";

        return $this->send($email, $name, $subject, $html, $altBody);
    }

    private function buildEmailTemplate(
        string $greeting,
        string $name,
        string $intro,
        string $bodyContent
    ): string {
        return <<<HTML
<!DOCTYPE html>
<html>
<head><meta charset="UTF-8"></head>
<body style="font-family:Arial,sans-serif;background:#f5f7fa;padding:24px;">
  <div style="max-width:520px;margin:0 auto;background:#fff;border-radius:12px;padding:32px;border-top:4px solid #1E5AA8;">
    <h2 style="color:#1E5AA8;margin:0 0 16px;">CTDHR Portal</h2>
    <p>{$greeting} <strong>{$name}</strong>,</p>
    <p>{$intro}</p>
    {$bodyContent}
    <hr style="border:none;border-top:1px solid #eee;margin:24px 0;">
    <p style="color:#999;font-size:11px;text-align:center;">Dhofar University &copy; CTDHR</p>
  </div>
</body>
</html>
HTML;
    }

    public function sendContactMessage(
        string $recipient,
        string $senderName,
        string $senderEmail,
        string $subject,
        string $message
    ): bool {
        $locale = $_SESSION['locale'] ?? config('locale', 'en');
        $isAr = $locale === 'ar';

        $mailSubject = $subject !== ''
            ? ($isAr ? 'رسالة تواصل: ' : 'Contact message: ') . $subject
            : ($isAr ? 'رسالة تواصل جديدة' : 'New contact message');

        $safeName = htmlspecialchars($senderName);
        $safeEmail = htmlspecialchars($senderEmail);
        $safeSubject = htmlspecialchars($subject !== '' ? $subject : ($isAr ? 'بدون موضوع' : 'No subject'));
        $safeMessage = nl2br(htmlspecialchars($message));

        $html = <<<HTML
<!DOCTYPE html>
<html>
<head><meta charset="UTF-8"></head>
<body style="font-family:Arial,sans-serif;background:#f5f7fa;padding:24px;">
  <div style="max-width:520px;margin:0 auto;background:#fff;border-radius:12px;padding:32px;border-top:4px solid #1E5AA8;">
    <h2 style="color:#1E5AA8;margin:0 0 16px;">CTDHR Contact Form</h2>
    <p><strong>Name:</strong> {$safeName}</p>
    <p><strong>Email:</strong> <a href="mailto:{$safeEmail}">{$safeEmail}</a></p>
    <p><strong>Subject:</strong> {$safeSubject}</p>
    <hr style="border:none;border-top:1px solid #eee;margin:20px 0;">
    <p>{$safeMessage}</p>
  </div>
</body>
</html>
HTML;

        $altBody = "Name: {$senderName}\nEmail: {$senderEmail}\nSubject: {$subject}\n\n{$message}";

        return $this->send($recipient, 'CTDHR Team', $mailSubject, $html, $altBody);
    }

    public function send(
        string $toEmail,
        string $toName,
        string $subject,
        string $htmlBody,
        string $altBody = ''
    ): bool {
        $altBody = $altBody !== '' ? $altBody : strip_tags($htmlBody);

        if ($this->isSmtpConfigured()) {
            try {
                $mail = $this->createMailer();
                $mail->addAddress($toEmail, $toName);
                $mail->isHTML(true);
                $mail->Subject = $subject;
                $mail->Body = $htmlBody;
                $mail->AltBody = $altBody;

                if ($mail->send()) {
                    $_SESSION['_last_mail_transport'] = 'smtp';

                    return true;
                }
            } catch (MailerException $e) {
                if (config('debug')) {
                    error_log('SMTP send failed, falling back to file: ' . $e->getMessage());
                }
            }
        }

        $fileResult = $this->sendViaFile($toEmail, $toName, $subject, $htmlBody, $altBody);
        $_SESSION['_last_mail_transport'] = $fileResult['transport'];

        return $fileResult['success'];
    }
}