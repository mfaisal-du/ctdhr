if (!function_exists('hero_title_parts')) {
    /** @return array{lead: string, accent: string} */
    function hero_title_parts(): array
    {
        $title = lang('hero_title');
        $locale = current_locale();

        if ($locale === 'en' && str_contains($title, ' & ')) {
            $parts = explode(' & ', $title, 2);

            return [
                'lead' => trim($parts[0]) . ' &',
                'accent' => trim($parts[1] ?? ''),
            ];
        }

        if ($locale === 'ar') {
            $words = preg_split('/\s+/u', trim($title), -1, PREG_SPLIT_NO_EMPTY) ?: [];
            if (count($words) > 3) {
                $mid = (int) ceil(count($words) / 2);

                return [
                    'lead' => implode(' ', array_slice($words, 0, $mid)),
                    'accent' => implode(' ', array_slice($words, $mid)),
                ];
            }
        }

        return ['lead' => $title, 'accent' => ''];
    }
}

