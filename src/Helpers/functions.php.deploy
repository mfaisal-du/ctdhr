        };
    }
}

if (!function_exists('rainbow_accent_style')) {
    function rainbow_accent_style(int $index = 0): string
    {
        $gradients = [
            '',
            'background: linear-gradient(90deg, #425AAD 0%, #00B0FF 100%);',
            'background: linear-gradient(90deg, #D81B60 0%, #FF7043 100%);',
            'background: linear-gradient(90deg, #30872F 0%, #FFD600 100%);',
        ];

        return $gradients[$index % count($gradients)];
    }
}

if (!function_exists('application_status_badge_class')) {
    function application_status_badge_class(string $status): string
    {
        $base = 'inline-flex items-center px-3 py-1 rounded-full text-label-sm font-semibold';

        return match ($status) {
            'approved' => $base . ' bg-status-completed/10 text-status-completed',
            'rejected' => $base . ' bg-status-cancelled/10 text-status-cancelled',
            'cancelled' => $base . ' bg-status-draft/10 text-status-draft',
            'waitlisted' => $base . ' bg-status-announced/10 text-status-announced',
            default => $base . ' bg-status-progress/10 text-status-progress',
        };
    }
}

if (!function_exists('news_ticker_resolve_href')) {
    function news_ticker_resolve_href(string $link): string
    {
        $link = trim($link);
        if ($link === '') {
            return url('/');
        }
        if (preg_match('#^https?://#i', $link) === 1) {
            return $link;
        }

        return url(ltrim($link, '/'));
    }
}