    function course_status_card_overlay_class(string $status): string
    {
        return match ($status) {
            'accepting_applications' => 'is-open',
            'announced' => 'is-announced',
            'scheduled' => 'is-scheduled',
            'in_progress' => 'is-progress',
            'completed' => 'is-completed',
            default => 'is-announced',
        };
    }
}

if (!function_exists('format_date')) {
    function format_date(?string $date): string
    {
        if ($date === null || $date === '') {
            return '-';
        }

        $timestamp = strtotime($date);
        if ($timestamp === false) {
            return $date;
        }

        $locale = current_locale();
        $format = $locale === 'ar' ? 'd/m/Y' : 'M j, Y';

        return date($format, $timestamp);
    }
}

if (!function_exists('pending_wait_days')) {
    function pending_wait_days(?string $createdAt): int
    {
        if ($createdAt === null || $createdAt === '') {
            return 0;
        }

        $timestamp = strtotime($createdAt);
        if ($timestamp === false) {
            return 0;
        }

        return max(0, (int) floor((time() - $timestamp) / 86400));
    }
}

if (!function_exists('pending_wait_label')) {
    function pending_wait_label(int $days): string
    {
        if ($days <= 0) {
            return lang('waiting_today');
        }

        if ($days === 1) {
            return lang('waiting_1_day');
        }

        return lang('waiting_n_days', ['days' => (string) $days]);
    }
}

if (!function_exists('pending_wait_urgency')) {
    /** @return 'normal'|'warning'|'critical' */
    function pending_wait_urgency(int $days): string
    {
        if ($days >= 7) {
            return 'critical';
        }

        if ($days >= 3) {
            return 'warning';
        }

        return 'normal';
    }
}

