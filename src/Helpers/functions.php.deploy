if (!function_exists('normalize_course_text')) {
    /**
     * Fix UTF-8 mojibake and normalize dashes in course content pulled from the database.
     */
    function normalize_course_text(string $text): string
    {
        if ($text === '') {
            return $text;
        }

        $replacements = [
            'ÔÇô' => '-',
            'ÔÇö' => '-',
            'â€“' => '-',
            'â€”' => '-',
            "\xE2\x80\x93" => '-',
            "\xE2\x80\x94" => '-',
            '–' => '-',
            '—' => '-',
        ];

        $normalized = str_replace(array_keys($replacements), array_values($replacements), $text);

        if (preg_match('/Ã|Â|Ô|â€/u', $normalized) === 1) {
            $decoded = @mb_convert_encoding($normalized, 'UTF-8', 'Windows-1252');
            if (is_string($decoded) && $decoded !== '' && mb_check_encoding($decoded, 'UTF-8')) {
                $normalized = str_replace(array_keys($replacements), array_values($replacements), $decoded);
            }
        }

        return $normalized;
    }
}

if (!function_exists('sanitize_rich_text')) {
    /**
     * Allow safe HTML from the admin rich-text editor on public pages.
     */
    function sanitize_rich_text(string $html): string
    {
        if ($html === '') {
            return '';
        }

        $allowed = '<p><br><strong><b><em><i><u><s><strike><h2><h3><ul><ol><li><a><blockquote><code><pre><span>';
        $clean = strip_tags($html, $allowed);

        return preg_replace('/\s(on\w+|style|class)\s*=\s*("|\').*?\2/i', '', $clean) ?? $clean;
    }
}

if (!function_exists('course_description_html')) {
    /**
     * @param array<string, mixed> $course
     */
    function course_description_html(array $course): string
    {
        $raw = trim(localized($course, 'description'));
        if ($raw === '') {
            return '';
        }

        if (preg_match('/<[^>]+>/', $raw) === 1) {
            return sanitize_rich_text($raw);
        }

        $parts = preg_split('/\n\s*\n/', $raw) ?: [];
        $paragraphs = array_values(array_filter(array_map('trim', $parts)));

        if ($paragraphs === []) {
            return '<p>' . e($raw) . '</p>';
        }

        return implode('', array_map(
            static fn (string $p): string => '<p>' . e($p) . '</p>',
            $paragraphs
        ));
    }
}

if (!function_exists('course_description_plain')) {
    /**
     * Plain-text excerpt from course description (for hero / cards).
     *
     * @param array<string, mixed> $course
     */
    function course_description_plain(array $course): string
    {
        $raw = trim(localized($course, 'description'));
        if ($raw === '') {
            return '';
        }

        $text = html_entity_decode(strip_tags($raw), ENT_QUOTES | ENT_HTML5, 'UTF-8');
        $text = preg_replace('/\s+/u', ' ', $text) ?? $text;

        return trim($text);
    }
}

if (!function_exists('course_description_paragraphs')) {
    /**
     * @param array<string, mixed> $course
     * @return list<string>
     */
    function course_description_paragraphs(array $course): array
    {
        $plain = course_description_plain($course);
        if ($plain === '') {
            return [];
        }

        $raw = trim(localized($course, 'description'));
        if (preg_match('/<[^>]+>/', $raw) === 1) {
            return [$plain];
        }

        $parts = preg_split('/\n\s*\n/', $plain) ?: [];
        $paragraphs = array_values(array_filter(array_map('trim', $parts)));

        return $paragraphs !== [] ? $paragraphs : [$plain];
    }
}

if (!function_exists('course_schedule_lines')) {
    /**
     * @param array<string, mixed> $course
     * @return list<string>
     */
    function course_schedule_lines(array $course): array
    {
        $raw = $course['session_dates'] ?? null;
        if (is_string($raw) && $raw !== '') {
            $decoded = json_decode($raw, true);
            if (is_array($decoded)) {
                return array_values(array_filter(array_map(
                    static fn ($line): string => normalize_course_text(trim((string) $line)),
                    $decoded
                )));
            }

            return array_values(array_filter(array_map(
                static fn (string $line): string => normalize_course_text(trim($line)),
                preg_split('/\r\n|\r|\n/', $raw) ?: []
            )));
        }

        if (is_array($raw)) {
            return array_values(array_filter(array_map(
                static fn ($line): string => normalize_course_text(trim((string) $line)),
                $raw
            )));
        }

        return [];
    }
}

if (!function_exists('attendance_session_entry_from_line')) {
    /**
     * @return array{key: string, number: int, label: string, detail: string, date: ?string}
     */
    function attendance_session_entry_from_line(string $line, int $number): array
    {
        $line = normalize_course_text(trim($line));
        $detail = $line;
        $date = null;

        if (preg_match('/^Session\s+\d+\s*[|\-–—]\s*(.+)$/iu', $line, $matches) === 1) {
            $detail = trim((string) $matches[1]);
        } elseif (preg_match('/^الجلسة\s+\d+\s*[|\-–—]\s*(.+)$/iu', $line, $matches) === 1) {
            $detail = trim((string) $matches[1]);
        }

        if (preg_match('/^(\d{4}-\d{2}-\d{2})\b/', $line, $matches) === 1) {
            $date = (string) $matches[1];
            $detail = trim(substr($line, strlen($matches[0])));
            $detail = ltrim($detail, "|–—- \t");
        } elseif (preg_match('/\b(\d{4}-\d{2}-\d{2})\b/', $line, $matches) === 1) {
            $date = (string) $matches[1];
        }

        $detailShort = $detail;
        if (mb_strlen($detailShort) > 52) {
            $detailShort = mb_substr($detailShort, 0, 49) . '…';
        }

        $label = lang('session_number', ['n' => (string) $number]);
        if ($date !== null) {
            $label .= ' · ' . format_date($date);
        }

        return [
            'key' => $line,
            'number' => $number,
            'label' => $label,
            'detail' => $detailShort,
            'date' => $date,
        ];
    }
}

if (!function_exists('attendance_session_entries')) {
    /**
     * @param array<string, mixed> $course
     * @return list<array{key: string, number: int, label: string, detail: string, date: ?string}>
     */
    function attendance_session_entries(array $course): array
    {
        $lines = course_schedule_lines($course);
        if ($lines === [] && !empty($course['start_date'])) {
            $lines = [normalize_course_text((string) $course['start_date'])];
        }
        if ($lines === []) {
            $lines = [date('Y-m-d')];
        }

        $entries = [];
        foreach ($lines as $index => $line) {
            $entries[] = attendance_session_entry_from_line($line, $index + 1);
        }

        return $entries;
    }
}

if (!function_exists('attendance_session_kpi_value')) {
    /**
