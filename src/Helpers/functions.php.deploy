if (!function_exists('course_status_badge_class')) {
    function course_status_badge_class(string $status): string
    {
        $base = 'inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-label-sm font-semibold';

        return match ($status) {
            'draft' => $base . ' bg-status-draft/10 text-status-draft',
            'announced', 'accepting_applications' => $base . ' bg-status-announced/10 text-status-announced',
            'scheduled' => $base . ' bg-status-scheduled/10 text-status-scheduled',
            'in_progress' => $base . ' bg-status-progress/10 text-status-progress',
            'completed' => $base . ' bg-status-completed/10 text-status-completed',
            'certified' => $base . ' bg-status-certified/10 text-status-certified',
            'cancelled' => $base . ' bg-status-cancelled/10 text-status-cancelled',
            default => $base . ' bg-surface-gray text-on-surface-variant',
        };
    }
}

