if (!function_exists('category_material_icon')) {
    function category_material_icon(string $icon): string
    {
        $icon = trim($icon);
        if ($icon === '') {
            return 'category';
        }

        if (str_starts_with($icon, 'mdi:')) {
            return match ($icon) {
                'mdi:laptop' => 'computer',
                'mdi:translate' => 'translate',
                'mdi:briefcase-outline' => 'work',
                'mdi:school-outline' => 'school',
                'mdi:account-tie' => 'supervisor_account',
                'mdi:heart-pulse' => 'health_and_safety',
                'mdi:monitor-cellphone' => 'devices',
                'mdi:account-voice' => 'record_voice_over',
                default => 'category',
            };
        }

        return $icon;
    }
}

if (!function_exists('category_icon_element')) {
    function category_icon_element(string $icon, string $sizeClass = 'text-[14px]'): string
    {
        $symbol = category_material_icon($icon);

        return '<span class="material-symbols-outlined ' . e($sizeClass) . '" aria-hidden="true">' . e($symbol) . '</span>';
    }
}

if (!function_exists('category_course_count_label')) {
    function category_course_count_label(int $count): string
