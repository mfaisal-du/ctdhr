if (!function_exists('attendance_session_option_label')) {
    /**
     * @param array{key: string, number: int, label: string, detail: string, date: ?string} $entry
     */
    function attendance_session_option_label(array $entry): string
    {
        $label = lang('session_number', ['n' => (string) $entry['number']]);

        if ($entry['detail'] !== '') {
            return $label . ' — ' . $entry['detail'];
        }

        if ($entry['date'] !== null) {
            return $label . ' — ' . format_date($entry['date']);
        }

        return $label;
    }
}

if (!function_exists('course_learning_outcomes')) {
    /**
     * @param array<string, mixed> $course
