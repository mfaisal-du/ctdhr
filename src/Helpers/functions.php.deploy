if (!function_exists('design_image')) {
    /**
     * Curated portal images sourced from du.edu.om (2025 + graduation galleries).
     *
     * @return array<string, string>
     */
    function design_images(): array
    {
        return [
            'hero' => 'du/2025/du2025-campus-wide.jpg',
            'hero_alt' => 'du/2025/du2025-event-02.jpg',
            'alumni' => 'du/graduation/graduation-ceremony-03.jpg',
            'graduation' => 'du/graduation/graduation-ceremony-02.jpg',
            'campus' => 'du/2025/du2025-campus-01.jpg',
            'faculty' => 'du/2025/du2025-training-02.jpg',
            'research' => 'du/2025/du2025-academic-01.jpg',
            'university' => 'du/2025/du2025-campus-02.jpg',
            'academic' => 'du/2025/du2025-academic-01.jpg',
            'training' => 'du/2025/du2025-training-01.jpg',
            'event' => 'du/2025/du2025-event-01.jpg',
            'placeholder' => 'du/2025/du2025-training-03.jpg',
        ];
    }

    function design_image(string $key): string
    {
        $images = design_images();
        $file = $images[$key] ?? $images['placeholder'];

        return asset('images/' . $file);
    }
}

if (!function_exists('image_dimensions')) {
    /**
     * @return array{w: int, h: int}|null
     */
    function image_dimensions(string $relativePath): ?array
    {
        static $cache = [];

        $relativePath = ltrim(str_replace('\\', '/', $relativePath), '/');

        if (isset($cache[$relativePath])) {
            return $cache[$relativePath];
        }

        $fullPath = CTDHR_PUBLIC . '/assets/images/' . $relativePath;

        if (!is_file($fullPath)) {
            $cache[$relativePath] = null;

            return null;
        }

        $size = getimagesize($fullPath);

        if ($size === false) {
            $cache[$relativePath] = null;

            return null;
        }

        $cache[$relativePath] = ['w' => (int) $size[0], 'h' => (int) $size[1]];

        return $cache[$relativePath];
    }
}

if (!function_exists('portal_img')) {
    /**
     * Renders a sharp, responsive <img> with intrinsic dimensions to prevent layout shift.
     *
     * Options: design|path|src, alt, class, loading, priority, sizes, cover
     *
     * @param array<string, mixed> $options
     */
    function portal_img(array $options): string
    {
        $relativePath = '';
        $src = (string) ($options['src'] ?? '');

        if (!empty($options['design'])) {
            $images = design_images();
            $relativePath = (string) ($images[$options['design']] ?? $images['placeholder']);
            $src = asset('images/' . $relativePath);
        } elseif (!empty($options['path'])) {
            $relativePath = ltrim(str_replace('\\', '/', (string) $options['path']), '/');
            $src = str_starts_with($relativePath, 'uploads/')
                ? asset($relativePath)
                : asset('images/' . $relativePath);
        }

        $alt = e((string) ($options['alt'] ?? ''));
        $priority = !empty($options['priority']);
        $loading = $priority ? 'eager' : (string) ($options['loading'] ?? 'lazy');
        $sizes = (string) ($options['sizes'] ?? '100vw');
        $cover = array_key_exists('cover', $options) ? (bool) $options['cover'] : true;

        $classes = trim((string) ($options['class'] ?? ''));
        $baseClass = $cover ? 'portal-img' : 'portal-img portal-img-contain';
        $classAttr = trim($baseClass . ($classes !== '' ? ' ' . $classes : ''));

        $attrs = [
            'src' => e($src),
            'alt' => $alt,
            'class' => e($classAttr),
            'decoding' => 'async',
            'loading' => e($loading),
        ];

        if ($priority) {
            $attrs['fetchpriority'] = 'high';
        }

        $dims = $relativePath !== '' ? image_dimensions($relativePath) : null;

        if ($dims !== null) {
            $attrs['width'] = (string) $dims['w'];
            $attrs['height'] = (string) $dims['h'];
            $attrs['sizes'] = e($sizes);
            $attrs['srcset'] = e($src . ' ' . $dims['w'] . 'w');
        }

        $html = '<img';

        foreach ($attrs as $name => $value) {
            $html .= ' ' . $name . '="' . $value . '"';
        }

        return $html . '>';
    }
}

if (!function_exists('course_cover_spec')) {
    /**
     * Recommended cover dimensions (matches public course card 16:10 ratio).
     *
     * @return array{width: int, height: int, ratio: string}
     */
    function course_cover_spec(): array
    {
        return [
            'width' => 1200,
            'height' => 750,
            'ratio' => '16:10',
        ];
    }
}

if (!function_exists('course_cover_relative')) {
    /**
     * @param array<string, mixed> $course
     */
    function course_cover_relative(array $course, int $fallbackIndex = 0): ?string
    {
        $path = trim((string) ($course['cover_image_path'] ?? ''));

        if ($path === '') {
            $gallery = du_gallery_images();
            $id = (int) ($course['id'] ?? 0);
            $index = $id > 0 ? ($id % count($gallery)) : ($fallbackIndex % count($gallery));

            return $gallery[$index];
        }

        if (str_starts_with($path, 'http://') || str_starts_with($path, 'https://')) {
            return null;
        }

        $relative = ltrim(str_replace('\\', '/', $path), '/');

        if (str_starts_with($relative, 'assets/')) {
            $relative = substr($relative, 7);
        }

        if (str_starts_with($relative, 'uploads/')) {
            return $relative;
        }

        if (str_starts_with($relative, 'images/')) {
            return substr($relative, 7);
        }

        return $relative;
    }
}

if (!function_exists('course_cover_asset_path')) {
    /**
     * Normalized asset-relative path for course cover (uploads/… or images/… segment).
     *
     * @param array<string, mixed> $course
     */
    function course_cover_asset_path(array $course, int $fallbackIndex = 0): string
    {
        $relative = course_cover_relative($course, $fallbackIndex);

        if ($relative !== null) {
            if (str_starts_with($relative, 'uploads/')) {
                return $relative;
            }

            return 'images/' . ltrim($relative, '/');
        }

        $path = trim((string) ($course['cover_image_path'] ?? ''));

        if ($path !== '' && (str_starts_with($path, 'http://') || str_starts_with($path, 'https://'))) {
            return $path;
        }

        $gallery = du_gallery_images();
        $id = (int) ($course['id'] ?? 0);
        $index = $id > 0 ? ($id % count($gallery)) : ($fallbackIndex % count($gallery));

        return 'images/' . $gallery[$index];
    }
}

if (!function_exists('course_cover')) {
    /**
     * @param array<string, mixed> $course
     */
    function course_cover(array $course): string
    {
        $assetPath = course_cover_asset_path($course);

        if (str_starts_with($assetPath, 'http://') || str_starts_with($assetPath, 'https://')) {
            return $assetPath;
        }

        return asset($assetPath);
    }
}

