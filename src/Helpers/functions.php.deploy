<?php

declare(strict_types=1);

if (!function_exists('env')) {
    function env(string $key, $default = null)
    {
        $value = $_ENV[$key] ?? $_SERVER[$key] ?? getenv($key);

        if ($value === false || $value === null) {
            return $default;
        }

        switch (strtolower((string) $value)) {
            case 'true':
            case '(true)':
                return true;
            case 'false':
            case '(false)':
                return false;
            case 'empty':
            case '(empty)':
                return '';
            case 'null':
            case '(null)':
                return null;
        }

        if (is_string($value) && strlen($value) >= 2) {
            $first = $value[0];
            $last = $value[strlen($value) - 1];
            if (($first === '"' && $last === '"') || ($first === "'" && $last === "'")) {
                return substr($value, 1, -1);
            }
        }

        return $value;
    }
}

if (!function_exists('config')) {
    function config(string $key, $default = null)
    {
        $config = $GLOBALS['app_config'] ?? [];

        if ($key === 'app') {
            return $config;
        }

        $keys = explode('.', $key);
        $value = $config;

        foreach ($keys as $segment) {
            if (!is_array($value) || !array_key_exists($segment, $value)) {
                return $default;
            }
            $value = $value[$segment];
        }

        return $value;
    }
}

if (!function_exists('lang')) {
    function lang(string $key, array $replace = []): string
    {
        static $translations = [];

        $locale = $_SESSION['locale'] ?? config('locale', 'en');

        if (!isset($translations[$locale])) {
            $langFile = CTDHR_LANG . '/' . $locale . '.php.deploy';
            if (!file_exists($langFile)) {
                $langFile = CTDHR_LANG . '/' . $locale . '.php';
            }
            if (file_exists($langFile)) {
                $translations[$locale] = require $langFile;
            } else {
                $translations[$locale] = [];
            }
        }

        $text = $translations[$locale][$key] ?? $translations['en'][$key] ?? $key;

        foreach ($replace as $search => $value) {
            $text = str_replace(':' . $search, (string) $value, $text);
        }

        return normalize_course_text($text);
    }
}

if (!function_exists('csrf_token')) {
    function csrf_token(): string
    {
        $tokenName = config('csrf_token_name', '_token');

        if (empty($_SESSION[$tokenName])) {
            $_SESSION[$tokenName] = bin2hex(random_bytes(32));
        }

        return $_SESSION[$tokenName];
    }
}

if (!function_exists('csrf_field')) {
    function csrf_field(): string
    {
        $tokenName = config('csrf_token_name', '_token');
        $token = csrf_token();

        return '<input type="hidden" name="' . e($tokenName) . '" value="' . e($token) . '">';
    }
}

if (!function_exists('asset')) {
    function asset(string $path): string
    {
        $baseUrl = config('url', '');
        $path = ltrim($path, '/');

        return $baseUrl . '/assets/' . $path;
    }
}

if (!function_exists('normalize_certificate_relative_path')) {
    function normalize_certificate_relative_path(string $pdfPath): string
    {
        $path = ltrim(trim($pdfPath), '/');
        if (str_starts_with($path, 'storage/certificates/')) {
            $path = 'uploads/certificates/' . substr($path, strlen('storage/certificates/'));
        }

        return $path;
    }
}

if (!function_exists('resolve_certificate_disk_path')) {
    /**
     * Locate a certificate PDF on disk (supports .pdf, .tmp seed copies, and .deploy seeds).
     */
    function resolve_certificate_disk_path(string $pdfPath): ?string
    {
        $pdfPath = trim($pdfPath);
        if ($pdfPath === '' || str_starts_with($pdfPath, 'http://') || str_starts_with($pdfPath, 'https://')) {
            return null;
        }

        $relative = normalize_certificate_relative_path($pdfPath);
        $basename = basename($relative);
        $nameWithoutExt = preg_replace('/\.pdf$/i', '', $basename) ?? $basename;

        $candidates = [
            CTDHR_PUBLIC . '/assets/' . $relative,
            CTDHR_ASSETS . '/' . $relative,
            CTDHR_PUBLIC . '/assets/' . preg_replace('/\.pdf$/i', '.tmp', $relative),
            CTDHR_ROOT . '/database/assets/certificates/demo/' . $basename . '.deploy',
            CTDHR_ROOT . '/database/assets/certificates/demo/' . $nameWithoutExt . '.pdf.deploy',
        ];

        foreach ($candidates as $file) {
            if (is_string($file) && is_file($file)) {
                return $file;
            }
        }

        return null;
    }
}

if (!function_exists('certificate_pdf_url')) {
    /**
     * Resolve a certificate PDF to a downloadable URL.
     */
    function certificate_pdf_url(string $pdfPath, ?int $certificateId = null): string
    {
        if ($certificateId !== null && $certificateId > 0) {
            return url('certificates/' . $certificateId . '/download');
        }

        $pdfPath = trim($pdfPath);
        if ($pdfPath === '') {
            return '';
        }

        if (str_starts_with($pdfPath, 'http://') || str_starts_with($pdfPath, 'https://')) {
            return $pdfPath;
        }

        return asset(normalize_certificate_relative_path($pdfPath));
    }
}

if (!function_exists('url')) {
    function url(string $path = ''): string
    {
        $baseUrl = config('url', '');
        $path = ltrim($path, '/');

        return $path === '' ? $baseUrl : $baseUrl . '/' . $path;
    }
}

if (!function_exists('flash')) {
    function flash(string $key, $value = null)
    {
        if ($value === null) {
            $message = $_SESSION['_flash'][$key] ?? null;
            unset($_SESSION['_flash'][$key]);

            return $message;
        }

        $_SESSION['_flash'][$key] = $value;
    }
}

if (!function_exists('old')) {
    function old(string $key, $default = '')
    {
        return $_SESSION['_old'][$key] ?? $default;
    }
}

if (!function_exists('e')) {
    function e(?string $value): string
    {
        return htmlspecialchars($value ?? '', ENT_QUOTES | ENT_SUBSTITUTE, 'UTF-8');
    }
}

if (!function_exists('view_path')) {
    function view_path(string $path): string
    {
        $path = ltrim(str_replace('\\', '/', $path), '/');

        if (substr($path, -7) === '.deploy') {
            return CTDHR_VIEWS . '/' . $path;
        }

        if (substr($path, -4) === '.php') {
            $deployPath = CTDHR_VIEWS . '/' . $path . '.deploy';
            if (file_exists($deployPath)) {
                return $deployPath;
            }

            return CTDHR_VIEWS . '/' . $path;
        }

        $deployPath = CTDHR_VIEWS . '/' . $path . '.php.deploy';
        if (file_exists($deployPath)) {
            return $deployPath;
        }

        return CTDHR_VIEWS . '/' . $path . '.php';
    }
}

if (!function_exists('view')) {
    function view(string $name, array $data = []): void
    {
        extract($data, EXTR_SKIP);

        $viewPath = view_path(str_replace('.', '/', $name) . '.php');

        if (!file_exists($viewPath)) {
            http_response_code(500);
            echo 'View not found: ' . e($name);
            exit(1);
        }

        require $viewPath;
    }
}

if (!function_exists('error_page')) {
    /**
     * @param array<string, mixed> $data
     */
    function error_page(int $statusCode, array $data = []): void
    {
        http_response_code($statusCode);
        view('errors.error', array_merge([
            'statusCode' => $statusCode,
        ], $data));
        exit;
    }
}

if (!function_exists('recaptcha_enabled')) {
    function recaptcha_enabled(): bool
    {
        static $enabled = null;
        if ($enabled === null) {
            $service = new \CTDHR\Services\RecaptchaService();
            $enabled = $service->isEnabled();
        }

        return $enabled;
    }
}

if (!function_exists('admin_view')) {
    function admin_view(string $name, array $data = []): void
    {
        extract($data, EXTR_SKIP);

        $viewPath = CTDHR_VIEWS . '/' . str_replace('.', '/', $name) . '.php.deploy';
        if (!file_exists($viewPath)) {
            $viewPath = CTDHR_VIEWS . '/' . str_replace('.', '/', $name) . '.php';
        }

        if (!file_exists($viewPath)) {
            http_response_code(500);
            echo 'View not found: ' . e($name);
            exit(1);
        }

        ob_start();
        require $viewPath;
        $content = ob_get_clean();
        require view_path('layouts/admin.php');
    }
}

if (!function_exists('slugify')) {
    function slugify(string $text): string
    {
        $text = strtolower(trim($text));
        $text = preg_replace('/[^a-z0-9\s-]/', '', $text) ?? '';
        $text = preg_replace('/[\s-]+/', '-', $text) ?? '';

        return trim($text, '-');
    }
}

if (!function_exists('dashboard_section')) {
    function dashboard_section(): string
    {
        $path = trim(request_relative_path(), '/');
        $parts = explode('/', $path);

        if (($parts[0] ?? '') !== 'dashboard') {
            return 'overview';
        }

        return $parts[1] ?? 'overview';
    }
}

if (!function_exists('dashboard_page_header')) {
    /**
     * @param array{icon?: string, title?: string, subtitle?: string, accent?: string, breadcrumbs?: list<array{label: string, href?: string}>, actions?: string} $config
     */
    function dashboard_page_header(array $config): void
    {
        $title = (string) ($config['title'] ?? '');
        $config['breadcrumbs'] = $config['breadcrumbs'] ?? [
            ['label' => lang('dashboard'), 'href' => url('dashboard')],
            ['label' => $title],
        ];

        admin_page_header($config);
    }
}

if (!function_exists('admin_section')) {
    function admin_section(): string
    {
        $uri = $_SERVER['REQUEST_URI'] ?? '';
        $basePath = parse_url(config('url', ''), PHP_URL_PATH) ?? '';
        if ($basePath !== '' && $basePath !== '/' && strpos($uri, $basePath) === 0) {
            $uri = substr($uri, strlen($basePath)) ?: '/';
        }

        $path = trim(parse_url($uri, PHP_URL_PATH) ?? '', '/');
        $parts = explode('/', $path);

        if (($parts[0] ?? '') !== 'admin') {
            return 'dashboard';
        }

        if (($parts[1] ?? '') === 'users' && ($parts[2] ?? '') === 'pending') {
            return 'users-pending';
        }

        return $parts[1] ?? 'dashboard';
    }
}

if (!function_exists('request_relative_path')) {
    /**
     * Resolve the current request path relative to the application base URL.
     * Supports both /public and non-/public entry points (root .htaccess rewrite).
     */
    function request_relative_path(?string $requestUri = null): string
    {
        $uri = parse_url($requestUri ?? ($_SERVER['REQUEST_URI'] ?? '/'), PHP_URL_PATH) ?? '/';
        $basePath = parse_url(config('url', ''), PHP_URL_PATH) ?? '';

        if ($basePath !== '' && $basePath !== '/' && str_starts_with($uri, $basePath)) {
            $uri = substr($uri, strlen($basePath)) ?: '/';
        } elseif ($basePath !== '' && $basePath !== '/') {
            $altBase = preg_replace('#/public$#', '', $basePath);
            if (is_string($altBase) && $altBase !== '' && $altBase !== $basePath && str_starts_with($uri, $altBase)) {
                $uri = substr($uri, strlen($altBase)) ?: '/';
            }
        }

        $uri = '/' . trim($uri, '/');

        return $uri === '/' ? '/' : rtrim($uri, '/');
    }
}

if (!function_exists('redirect')) {
    function redirect(string $path, int $status = 303): void
    {
        header('Location: ' . url($path), true, $status);
        exit;
    }
}

if (!function_exists('is_rtl')) {
    function is_rtl(): bool
    {
        $locale = $_SESSION['locale'] ?? config('locale', 'en');

        return $locale === 'ar';
    }
}

if (!function_exists('current_locale')) {
    function current_locale(): string
    {
        return $_SESSION['locale'] ?? config('locale', 'en');
    }
}

if (!function_exists('demo_logins_enabled')) {
    function demo_logins_enabled(): bool
    {
        return filter_var(config('demo_logins.enabled', false), FILTER_VALIDATE_BOOLEAN);
    }
}

if (!function_exists('demo_login_accounts')) {
    /**
     * @return array<int, array<string, string>>
     */
    function demo_login_accounts(): array
    {
        if (!demo_logins_enabled()) {
            return [];
        }

        $accounts = config('demo_logins.accounts', []);
        if (!is_array($accounts)) {
            return [];
        }

        $resolved = [];

        foreach ($accounts as $account) {
            if (!is_array($account) || empty($account['email']) || !array_key_exists('password', $account)) {
                continue;
            }

            $labelKey = $account['label_key'] ?? '';
            $resolved[] = [
                'id' => (string) ($account['id'] ?? $account['email']),
                'label' => $labelKey !== '' ? lang($labelKey) : (string) ($account['label'] ?? $account['email']),
                'email' => (string) $account['email'],
                'password' => (string) $account['password'],
                'role' => (string) ($account['role'] ?? 'user'),
                'icon' => (string) ($account['icon'] ?? 'person'),
            ];
        }

        return $resolved;
    }
}

if (!function_exists('is_arabic_text_corrupted')) {
    function is_arabic_text_corrupted(string $text): bool
    {
        $text = trim($text);
        if ($text === '') {
            return false;
        }

        return preg_match('/\?{2,}/', $text) === 1
            || preg_match('/^[\x{003F}\s]+$/u', $text) === 1;
    }
}

if (!function_exists('arabic_display_value')) {
    function arabic_display_value(string $value, string $fallback = ''): string
    {
        $value = normalize_course_text($value);
        if ($value !== '' && !is_arabic_text_corrupted($value)) {
            return $value;
        }

        return $fallback !== '' ? normalize_course_text($fallback) : '';
    }
}

if (!function_exists('localized')) {
    /**
     * @param array<string, mixed> $row
     */
    function localized(array $row, string $field): string
    {
        $locale = current_locale();
        $localizedKey = $field . '_' . $locale;
        $fallbackKey = $field . '_en';

        $value = '';
        if (!empty($row[$localizedKey])) {
            $value = (string) $row[$localizedKey];
            if ($locale === 'ar' && is_arabic_text_corrupted($value)) {
                $value = !empty($row[$fallbackKey])
                    ? (string) $row[$fallbackKey]
                    : (string) ($row[$field] ?? '');
            }
        } elseif (!empty($row[$fallbackKey])) {
            $value = (string) $row[$fallbackKey];
        } else {
            $value = (string) ($row[$field] ?? '');
        }

        return normalize_course_text($value);
    }
}

