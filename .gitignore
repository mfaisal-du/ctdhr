/vendor/
/node_modules/
/vendor-local/

# Build / cache / logs
/storage/logs/*
/storage/cache/*
/storage/mail/*
!/storage/logs/.gitkeep
!/storage/cache/.gitkeep
!/storage/mail/.gitkeep
/tmp/
