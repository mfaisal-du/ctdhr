# Application
APP_NAME="CTDHR Portal"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/CTDHR_Portal/Portal/public

# Development login shortcuts on /login (disable in production)
DEMO_LOGINS_ENABLED=true
DEMO_ADMIN_EMAIL=mfaisal@du.edu.om
DEMO_ADMIN_PASSWORD=Admin@123
APP_TIMEZONE=Asia/Dubai
APP_LOCALE=en

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ctdhr_portal
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# SMTP / Mail (runtime settings from Admin → Settings → SMTP take priority)
# Gmail example: host=smtp.gmail.com, port=587, encryption=tls, use a Google App Password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="CTDHR Portal"

# LDAP / Active Directory
LDAP_HOST=ldap://du.edu.om
LDAP_PORT=389
LDAP_BASE_DN=DC=du,DC=edu,DC=om
LDAP_BIND_DN=CN=service_account,OU=ServiceAccounts,DC=du,DC=edu,DC=om
LDAP_BIND_PASSWORD=
LDAP_USE_TLS=false

# Session
SESSION_LIFETIME=120
SESSION_SECURE=false
SESSION_HTTPONLY=true
SESSION_SAMESITE=Lax